<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InputBusX.UI.ViewModels"
             x:Class="InputBusX.UI.Views.MacroEditorView"
             x:DataType="vm:MacroEditorViewModel">

    <Grid ColumnDefinitions="300,*" Margin="4">
        <!-- Macro List Sidebar -->
        <Border Classes="card card-interactive" Grid.Column="0" Margin="0,0,10,0" Padding="16">
            <DockPanel>

                <!-- Header row: label + Add button -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                    <TextBlock Grid.Column="0" Text="MACROS" Classes="eyebrow"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="+ New" Command="{Binding AddMacroCommand}"
                            Classes="accent" Padding="12,6" MinHeight="30"
                            ToolTip.Tip="Criar novo macro (Ctrl+N)"
                            AutomationProperties.Name="Add new macro" />
                </Grid>

                <!-- Action buttons row -->
                <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0"
                      ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                    <Button Grid.Row="0" Grid.Column="0"
                            Content="Delete" Command="{Binding DeleteMacroCommand}"
                            Classes="danger" Padding="8,6" MinHeight="30"
                            Margin="0,0,4,4"
                            ToolTip.Tip="Deletar macro selecionado (Del)"
                            AutomationProperties.Name="Delete selected macro" />
                    <Button Grid.Row="0" Grid.Column="1"
                            Content="⬇ Import" Command="{Binding ImportMacrosCommand}"
                            Classes="secondary" Padding="8,6" MinHeight="30"
                            Margin="0,0,4,4"
                            ToolTip.Tip="Importar macros de .matrixmacros"
                            AutomationProperties.Name="Import macros" />
                    <Button Grid.Row="0" Grid.Column="2"
                            Content="⬆ Export" Command="{Binding ExportSelectedMacroCommand}"
                            Classes="ghost" Padding="8,6" MinHeight="30"
                            Margin="0,0,0,4"
                            ToolTip.Tip="Exportar macro selecionado"
                            AutomationProperties.Name="Export selected macro" />
                    <Button Grid.Row="1" Grid.ColumnSpan="3"
                            Content="⬆⬆ Export All" Command="{Binding ExportAllMacrosCommand}"
                            Classes="ghost" Padding="8,6" MinHeight="30"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Exportar todos os macros"
                            AutomationProperties.Name="Export all macros" />
                </Grid>

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="8" Margin="0,24"
                            IsVisible="{Binding !Macros.Count}">
                    <TextBlock Text="✦" FontSize="22" Foreground="#2A3345"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Nenhum macro ainda." Foreground="#4A5066"
                               FontStyle="Italic" TextAlignment="Center" FontSize="12" />
                    <TextBlock Text="Clique em + New para criar." Foreground="#2A3345"
                               TextAlignment="Center" FontSize="11" />
                </StackPanel>

                <!-- Macro cards list -->
                <ListBox ItemsSource="{Binding Macros}"
                         SelectedItem="{Binding SelectedMacro}"
                         Background="Transparent"
                         AutomationProperties.Name="Macro list">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,6" />
                            <Setter Property="CornerRadius" Value="10" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                                <Border Classes="item-card" CornerRadius="10" Padding="12,10"
                                    Background="#161A24"
                                    BorderThickness="1"
                                    BorderBrush="#1F2533">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Status indicator -->
                                    <Panel Grid.Column="0" Width="3" Margin="0,0,10,0">
                                        <Border CornerRadius="2" Background="#00FF95"
                                                VerticalAlignment="Stretch"
                                                IsVisible="{Binding Enabled}" />
                                        <Border CornerRadius="2" Background="#2A3345"
                                                VerticalAlignment="Stretch"
                                                IsVisible="{Binding !Enabled}" />
                                    </Panel>
                                    <!-- Name + type -->
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   FontSize="13" Foreground="#F0F2F8" />
                                        <TextBlock Text="{Binding Type}" FontSize="10"
                                                   Foreground="#4A5066" />
                                    </StackPanel>
                                    <!-- Enabled dot -->
                                    <Ellipse Grid.Column="2" Width="6" Height="6"
                                             VerticalAlignment="Center"
                                             Fill="#00FF95" IsVisible="{Binding Enabled}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Macro Editor Panel -->
        <Border Classes="card card-interactive" Grid.Column="1">
            <Panel>

            <!-- Empty state when no macro selected -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12"
                        IsVisible="{Binding SelectedMacro, Converter={x:Static ObjectConverters.IsNull}}">
                <TextBlock Text="✦" FontSize="32" Foreground="#2A3345"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Nenhum macro selecionado"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#4A5066" HorizontalAlignment="Center" />
                <TextBlock Text="Selecione um macro da lista, ou crie um novo."
                           Foreground="#2A3345" FontSize="12"
                           TextAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="260" HorizontalAlignment="Center" />
                <Border Background="#161A24" BorderBrush="#2A3345" BorderThickness="1"
                        CornerRadius="8" Padding="12,6" HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                    <TextBlock Text="Ctrl+N  →  novo macro"
                               FontSize="11" Foreground="#4A5066"
                               FontFamily="JetBrains Mono,Consolas,Courier New" />
                </Border>
            </StackPanel>

            <!-- Editor with sticky save footer (DockPanel keeps footer always visible) -->
            <DockPanel IsVisible="{Binding SelectedMacro, Converter={x:Static ObjectConverters.IsNotNull}}">

                <!-- ── Sticky save footer ── -->
                <Border DockPanel.Dock="Bottom"
                        Background="#0A0D13"
                        BorderBrush="#1F2533"
                        BorderThickness="0,1,0,0"
                        Padding="8,12,8,8"
                        Margin="0,12,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <Border Background="#161A24" BorderBrush="#2A3345" BorderThickness="1"
                                    CornerRadius="6" Padding="8,3">
                                <TextBlock Text="Ctrl+S" FontSize="10" Foreground="#4A5066"
                                           FontFamily="JetBrains Mono,Consolas,Courier New" />
                            </Border>
                            <TextBlock Text="para salvar alterações"
                                       FontSize="11" Foreground="#4A5066"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{Binding SaveStatus}"
                                       Foreground="#00FF95" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Content="Salvar Macro"
                                    Command="{Binding SaveMacroCommand}"
                                    Classes="accent"
                                    ToolTip.Tip="Salva as alterações deste macro (Ctrl+S)"
                                    AutomationProperties.Name="Save macro settings" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Scrollable settings ── -->
                <ScrollViewer>
                <StackPanel Spacing="14" Margin="0,0,4,0">
                    <TextBlock Text="Macro Settings" Classes="section-header" />

                    <!-- ============ GENERAL ============ -->
                    <!-- Name -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Name" Classes="label" />
                        <TextBox Text="{Binding MacroName}" Watermark="Macro name..."
                                 AutomationProperties.Name="Macro name" />
                    </StackPanel>

                    <!-- Type + Enabled -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Type" Classes="label" />
                            <ComboBox ItemsSource="{Binding MacroTypes}"
                                      SelectedItem="{Binding SelectedMacroType}"
                                      MinWidth="200"
                                      AutomationProperties.Name="Macro type" />
                        </StackPanel>
                        <CheckBox Grid.Column="1" Content="Enabled" IsChecked="{Binding MacroEnabled}"
                                  VerticalAlignment="Bottom" Margin="12,0,0,0"
                                  AutomationProperties.Name="Macro enabled" />
                    </Grid>

                    <!-- Activation Button (all types) -->
                    <Border Classes="section-panel" BorderBrush="#00FF9C" BorderThickness="3,0,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Activation" FontWeight="SemiBold" FontSize="14" Foreground="#00FF9C" />
                            <TextBlock Text="Button that triggers this macro (hold or press)"
                                       Classes="label" TextWrapping="Wrap" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="Trigger Button" Classes="label" />
                                <ComboBox ItemsSource="{Binding ButtonList}"
                                          SelectedItem="{Binding ActivationButton}"
                                          MinWidth="200"
                                          AutomationProperties.Name="Activation button" />
                            </StackPanel>
                            <CheckBox Content="Toggle mode (press once to activate, again to deactivate)"
                                      IsChecked="{Binding ToggleMode}"
                                      AutomationProperties.Name="Toggle mode" />
                        </StackPanel>
                    </Border>

                    <!-- Priority -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Priority (higher = runs first)" Classes="label" />
                        <NumericUpDown Value="{Binding MacroPriority}" Minimum="0" Maximum="100"
                                       AutomationProperties.Name="Macro priority"
                                       ToolTip.Tip="When multiple macros are active at once, they run in descending priority order. Use this to control which macro's output wins." />
                    </StackPanel>

                    <Separator />

                    <!-- ============ AUTO PING ============ -->
                    <Border Classes="section-panel" BorderBrush="#FFD93D" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowAutoPingSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Auto Ping Settings" FontWeight="SemiBold" FontSize="14" Foreground="#FFD93D" />
                            <TextBlock Text="Automatically pings while you hold RT. Choose which button gets pressed and how often it repeats."
                                       Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A" />

                            <StackPanel Spacing="4">
                                <TextBlock Text="Ping Button" Classes="label" />
                                <ComboBox ItemsSource="{Binding ButtonList}"
                                          SelectedItem="{Binding PingButton}"
                                          MinWidth="200"
                                          AutomationProperties.Name="Ping button" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Ping Interval (ms)" Classes="label" />
                                <NumericUpDown Value="{Binding MacroIntervalMs}" Minimum="50" Maximum="5000"
                                               Increment="50"
                                               AutomationProperties.Name="Ping interval in ms" />
                                <TextBlock Text="How often the ping button is pressed (200ms = 5x per second)"
                                           FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>

                            <CheckBox Content="Loop continuously while held"
                                      IsChecked="{Binding MacroLoop}"
                                      AutomationProperties.Name="Loop ping" />
                        </StackPanel>
                    </Border>

                    <!-- ============ AUTO FIRE ============ -->
                    <Border Classes="section-panel" BorderBrush="#FF8C42" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowAutoFireSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Auto Fire Settings" FontWeight="SemiBold" FontSize="14" Foreground="#FF8C42" />
                            <TextBlock Text="Rapidamente pressiona e solta o trigger enquanto você segura. Use RT para pistolas semi-auto."
                                       Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A" />

                            <StackPanel Spacing="4">
                                <TextBlock Text="Trigger de Ativação" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}"
                                          SelectedItem="{Binding TriggerSource}"
                                          MinWidth="200"
                                          AutomationProperties.Name="Auto fire trigger source" />
                                <TextBlock Text="RT = gatilho direito (atirar). LT = gatilho esquerdo (mirar)."
                                           FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Fire Interval (ms)" Classes="label" />
                                <NumericUpDown Value="{Binding MacroIntervalMs}" Minimum="10" Maximum="1000"
                                               Increment="10"
                                               AutomationProperties.Name="Fire interval in ms"
                                               ToolTip.Tip="Time between each simulated trigger press/release cycle (milliseconds). Lower = faster fire rate. 40ms = very fast (~25 shots/s), 80ms = moderate (~12 shots/s). Stay above the weapon's actual fire rate for best results." />
                                <TextBlock Text="Menor = mais rápido (40ms = muito rápido, 80ms = moderado)"
                                           FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>

                            <CheckBox Content="Loop" IsChecked="{Binding MacroLoop}"
                                      AutomationProperties.Name="Loop auto fire" />
                        </StackPanel>
                    </Border>

                    <!-- ============ NO RECOIL ============ -->
                    <Border Classes="section-panel" BorderBrush="#FF6B6B" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowNoRecoilSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="No Recoil Settings" FontWeight="SemiBold" FontSize="14" Foreground="#FF6B6B" />
                            <TextBlock Text="Compensates weapon recoil by pulling the right stick down while RT is held."
                                       Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A" />
                            <TextBlock Text="If you want an extra modifier, pick an activation button above."
                                       Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A" />

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Compensation X" Classes="label" />
                                    <NumericUpDown Value="{Binding RecoilCompensationX}"
                                                   Minimum="-32767" Maximum="32767" Increment="500"
                                                   AutomationProperties.Name="Recoil X"
                                                   ToolTip.Tip="Horizontal correction added to the right stick each frame while firing. Positive = push right, Negative = push left. Most weapons need 0 here." />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Compensation Y (negativo = baixo)" Classes="label" />
                                    <NumericUpDown Value="{Binding RecoilCompensationY}"
                                                   Minimum="-32767" Maximum="32767" Increment="500"
                                                   AutomationProperties.Name="Recoil Y"
                                                   ToolTip.Tip="Vertical correction added to the right stick each frame while firing. Negative pulls the stick DOWN to counteract upward recoil. Start at -5000 and tune until crosshair stays flat. Range: ±32767 (full stick deflection)." />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Range do analógico: -32767 (máximo baixo) a 32767 (máximo cima). Comece com Y=-5000 e ajuste."
                                       FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />

                            <StackPanel Spacing="4">
                                <TextBlock Text="Trigger Source" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}"
                                          SelectedItem="{Binding TriggerSource}"
                                          MinWidth="200"
                                          AutomationProperties.Name="No recoil trigger source" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="label"
                                           ToolTip.Tip="Scales the compensation values. 100% = full strength. 50% = half the recoil correction. Values above 100% amplify the correction beyond the configured values. Use this to fine-tune without changing the raw numbers.">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Intensity: {0:P0}">
                                            <Binding Path="MacroIntensity" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Slider Value="{Binding MacroIntensity}" Minimum="0" Maximum="2" TickFrequency="0.05"
                                    ToolTip.Placement="Top"
                                    ToolTip.ShowDelay="0"
                                    ToolTip.Tip="{Binding MacroIntensity, StringFormat='Intensity {0:P0}'}"
                                    AutomationProperties.Name="Recoil intensity" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="label"
                                           ToolTip.Tip="Adds a small random offset to each frame's compensation so the pattern is never perfectly identical. Higher values = more variation. Recommended: 10–20% to avoid detection patterns while keeping recoil controlled.">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Randomization: {0:P0}">
                                            <Binding Path="MacroRandomization" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Slider Value="{Binding MacroRandomization}" Minimum="0" Maximum="1"
                                    ToolTip.Placement="Top"
                                    ToolTip.ShowDelay="0"
                                    ToolTip.Tip="{Binding MacroRandomization, StringFormat='Randomization {0:P0}'}"
                                    AutomationProperties.Name="Recoil randomization" />
                                <TextBlock Text="Adds random variation to avoid detection patterns"
                                           FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ============ AIM ASSIST BUFF ============ -->
                    <Border Classes="section-panel" BorderBrush="#00DDFF" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowAimAssistBuffSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Aim Assist Buff" FontWeight="SemiBold" FontSize="14" Foreground="#00DDFF" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Quando LT for pressionado (mirando), o analógico ESQUERDO faz flicks rápidos de um lado pro outro para maximizar o aim assist do jogo. Sem LT = analógico normal." />

                            <StackPanel Spacing="4">
                                <TextBlock Text="Trigger de Ativação" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}"
                                          SelectedItem="{Binding TriggerSource}"
                                          MinWidth="200"
                                          AutomationProperties.Name="Aim assist trigger source" />
                                <TextBlock Text="LT = apertar para mirar (ADS). RT = apertar para atirar."
                                           FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="label"
                                           ToolTip.Tip="How far the left stick flicks to each side (in raw axis units, range 0–32767). Maximum deflection (32767) gives the strongest possible aim-assist bubble trigger. Recommended: 32767 for Warzone/Apex, 20000 for more subtle assist.">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Força do Flick: {0} / 32767">
                                            <Binding Path="FlickStrength" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Slider Value="{Binding FlickStrength}"
                                        Minimum="5000" Maximum="32767" TickFrequency="1000"
                                    ToolTip.Placement="Top"
                                    ToolTip.ShowDelay="0"
                                    ToolTip.Tip="{Binding FlickStrength, StringFormat='Flick {0:F0}'}"
                                    AutomationProperties.Name="Flick strength" />
                                <TextBlock Text="32767 = deflexão máxima (recomendado para Warzone)"
                                           FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="label"
                                           ToolTip.Tip="Time in milliseconds spent at each extreme (left and right) per flick cycle. Lower = faster oscillation = more aim assist hits per second. 6–12ms is ideal for most Battle Royale games. Below 4ms may not register on all games.">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Velocidade do Flick: {0}ms por lado">
                                            <Binding Path="FlickIntervalMs" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <NumericUpDown Value="{Binding FlickIntervalMs}"
                                               Minimum="4" Maximum="100" Increment="2"
                                               AutomationProperties.Name="Flick interval ms"
                                               ToolTip.Tip="Time each flick position is held (ms). 8ms ≈ 125 flicks/s. Lower = faster oscillation, stronger effect. Recommended: 6–12ms." />
                                <TextBlock FontSize="10" Foreground="#4A4F5A"
                                           Text="Menor = flick mais rápido. 8ms ≈ 125 flicks/s. Warzone: 6–12ms." />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ============ REMAP ============ -->
                    <Border Classes="section-panel" BorderBrush="#B388FF" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowRemapSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Remap Settings" FontWeight="SemiBold" FontSize="14" Foreground="#B388FF" />
                            <TextBlock Text="Remap one button to another. When you press Source, it sends Target instead."
                                       Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A" />

                            <Grid ColumnDefinitions="*,Auto,*">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Source Button" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ButtonList}"
                                              SelectedItem="{Binding SourceButton}"
                                              AutomationProperties.Name="Source button for remap" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="-->" VerticalAlignment="Center"
                                           Margin="12,16,12,0" FontSize="16" Foreground="#4A4F5A" />
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Target Button" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ButtonList}"
                                              SelectedItem="{Binding TargetButton}"
                                              AutomationProperties.Name="Target button for remap" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ============ SCRIPTED SHAPE ============ -->
                    <Border Classes="section-panel" BorderBrush="#7C5CFF" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowScriptedShapeSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Scripted Shape" FontWeight="SemiBold" FontSize="14" Foreground="#7C5CFF" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Movimento paramétrico do analógico: círculo, oval, flick. Enquanto o botão de ativação estiver ativo, a forma é aplicada (aditivo ou override)." />

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Forma" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ShapeKinds}" SelectedItem="{Binding Shape}" MinWidth="160" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Analógico alvo" Classes="label" />
                                    <ComboBox ItemsSource="{Binding StickTargetKinds}" SelectedItem="{Binding StickTarget}" MinWidth="160" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Raio X (0..1)" Classes="label" />
                                    <NumericUpDown Value="{Binding RadiusXNorm}" Minimum="0" Maximum="1" Increment="0.05" FormatString="F2" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Raio Y (0..1)" Classes="label" />
                                    <NumericUpDown Value="{Binding RadiusYNorm}" Minimum="0" Maximum="1" Increment="0.05" FormatString="F2" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Rotação (°)" Classes="label" />
                                    <NumericUpDown Value="{Binding RotationDeg}" Minimum="-360" Maximum="360" Increment="5" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Período (ms) — 1 revolução" Classes="label" />
                                    <NumericUpDown Value="{Binding PeriodMs}" Minimum="50" Maximum="5000" Increment="50" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Duração total (ms) — 0 = infinito" Classes="label" />
                                    <NumericUpDown Value="{Binding MotionDurationMs}" Minimum="0" Maximum="10000" Increment="50" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Fase inicial (°)" Classes="label" />
                                    <NumericUpDown Value="{Binding StartPhaseDeg}" Minimum="-360" Maximum="360" Increment="5" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Direção do Flick (°)" Classes="label" />
                                    <NumericUpDown Value="{Binding DirectionDeg}" Minimum="-360" Maximum="360" Increment="5" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Amplitude do Flick (0..1)" Classes="label" />
                                    <NumericUpDown Value="{Binding AmplitudeNorm}" Minimum="0" Maximum="1" Increment="0.05" FormatString="F2" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Easing" Classes="label" />
                                    <ComboBox ItemsSource="{Binding EasingKinds}" SelectedItem="{Binding Easing}" MinWidth="160" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Multiplicador de intensidade" Classes="label" />
                                    <NumericUpDown Value="{Binding IntensityMul}" Minimum="0" Maximum="3" Increment="0.1" FormatString="F2" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <CheckBox Content="Horário" IsChecked="{Binding Clockwise}" />
                                <CheckBox Content="Aditivo (somar ao input do jogador)" IsChecked="{Binding Additive}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Gatilho de ativação" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}"
                                          SelectedItem="{Binding TriggerSource}"
                                          MinWidth="200" />
                                <TextBlock Text="None = ativado apenas pelo botão acima. RT/LT = também exige o gatilho pressionado."
                                           FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ============ HEAD ASSIST ============ -->
                    <Border Classes="section-panel" BorderBrush="#FF2D7A" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowHeadAssistSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Head Assist" FontWeight="SemiBold" FontSize="14" Foreground="#FF2D7A" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Mini flick no analógico esquerdo para travar HS quando o inimigo pula. Três presets (curto/médio/longo) são escolhidos pela distância estimada em tempo real." />

                            <StackPanel Spacing="4">
                                <TextBlock Text="Gatilho de tiro" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}" MinWidth="200" />
                                <TextBlock Text="RT = padrão (atirar). Mudar só se a arma atual usa LT."
                                           FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Analógico alvo" Classes="label" />
                                    <ComboBox ItemsSource="{Binding StickTargetKinds}" SelectedItem="{Binding HaStickTarget}" MinWidth="160" />
                                    <TextBlock Text="Right = stick de MIRA (padrão FPS). Left = stick de movimento."
                                               FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Modo" Classes="label" />
                                    <CheckBox Content="Aditivo (soma ao input do jogador)" IsChecked="{Binding HaAdditive}" />
                                    <TextBlock Text="Desmarcado = override total do stick enquanto o flick roda."
                                               FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Border Background="#1A1D22" CornerRadius="4" Padding="10,8">
                                <TextBlock FontSize="11" Foreground="#FFD93D" TextWrapping="Wrap"
                                           Text="Direção: 90° = sobe (padrão). Se seu jogo está com Y invertido e o flick vai pra baixo, mude as 3 direções abaixo para 270°." />
                            </Border>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Fonte da distância" Classes="label" />
                                <ComboBox ItemsSource="{Binding DistanceSources}" SelectedItem="{Binding DistanceSource}" MinWidth="200" />
                                <TextBlock Text="Auto = fusão ponderada dos 3 sinais (recomendado)."
                                           FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>

                            <!-- Short range -->
                            <Border Classes="section-panel" BorderBrush="#00FF9C" BorderThickness="2,0,0,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Curto alcance" FontWeight="SemiBold" Foreground="#00FF9C" />
                                    <Grid ColumnDefinitions="*,*,*">
                                        <StackPanel Spacing="4" Margin="0,0,6,0">
                                            <TextBlock Text="Amplitude" Classes="label" />
                                            <NumericUpDown Value="{Binding HaShortAmp}" Minimum="0" Maximum="1" Increment="0.05" FormatString="F2" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,6,0">
                                            <TextBlock Text="Duração (ms)" Classes="label" />
                                            <NumericUpDown Value="{Binding HaShortDurMs}" Minimum="20" Maximum="1000" Increment="10" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="Direção (°)" Classes="label" />
                                            <NumericUpDown Value="{Binding HaShortDirDeg}" Minimum="0" Maximum="360" Increment="5" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Medium range -->
                            <Border Classes="section-panel" BorderBrush="#FFD93D" BorderThickness="2,0,0,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Médio alcance" FontWeight="SemiBold" Foreground="#FFD93D" />
                                    <Grid ColumnDefinitions="*,*,*">
                                        <StackPanel Spacing="4" Margin="0,0,6,0">
                                            <TextBlock Text="Amplitude" Classes="label" />
                                            <NumericUpDown Value="{Binding HaMediumAmp}" Minimum="0" Maximum="1" Increment="0.05" FormatString="F2" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,6,0">
                                            <TextBlock Text="Duração (ms)" Classes="label" />
                                            <NumericUpDown Value="{Binding HaMediumDurMs}" Minimum="20" Maximum="1000" Increment="10" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="Direção (°)" Classes="label" />
                                            <NumericUpDown Value="{Binding HaMediumDirDeg}" Minimum="0" Maximum="360" Increment="5" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Long range -->
                            <Border Classes="section-panel" BorderBrush="#FF6B6B" BorderThickness="2,0,0,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Longo alcance" FontWeight="SemiBold" Foreground="#FF6B6B" />
                                    <Grid ColumnDefinitions="*,*,*">
                                        <StackPanel Spacing="4" Margin="0,0,6,0">
                                            <TextBlock Text="Amplitude" Classes="label" />
                                            <NumericUpDown Value="{Binding HaLongAmp}" Minimum="0" Maximum="1" Increment="0.05" FormatString="F2" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,6,0">
                                            <TextBlock Text="Duração (ms)" Classes="label" />
                                            <NumericUpDown Value="{Binding HaLongDurMs}" Minimum="20" Maximum="1000" Increment="10" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="Direção (°)" Classes="label" />
                                            <NumericUpDown Value="{Binding HaLongDirDeg}" Minimum="0" Maximum="360" Increment="5" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Thresholds -->
                            <TextBlock Text="Limiares do estimador" FontWeight="SemiBold" Foreground="#EAEAEA" Margin="0,4,0,0" />
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Trigger hold curto (ms)" Classes="label" />
                                    <NumericUpDown Value="{Binding ShortHoldMsMax}" Minimum="20" Maximum="2000" Increment="10" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Trigger hold médio (ms)" Classes="label" />
                                    <NumericUpDown Value="{Binding MediumHoldMsMax}" Minimum="50" Maximum="5000" Increment="50" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Deflexão curta (0..1)" Classes="label" />
                                    <NumericUpDown Value="{Binding DeflectionShortMax}" Minimum="0" Maximum="1" Increment="0.05" FormatString="F2" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Deflexão média (0..1)" Classes="label" />
                                    <NumericUpDown Value="{Binding DeflectionMediumMax}" Minimum="0" Maximum="1" Increment="0.05" FormatString="F2" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Recoil curto (magnitude)" Classes="label" />
                                    <NumericUpDown Value="{Binding RecoilShortMax}" Minimum="0" Maximum="32767" Increment="250" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Recoil médio (magnitude)" Classes="label" />
                                    <NumericUpDown Value="{Binding RecoilMediumMax}" Minimum="0" Maximum="32767" Increment="250" />
                                </StackPanel>
                            </Grid>

                            <!-- Fusion weights -->
                            <TextBlock Text="Pesos da fusão (Auto)" FontWeight="SemiBold" Foreground="#EAEAEA" Margin="0,4,0,0" />
                            <Grid ColumnDefinitions="*,*,*">
                                <StackPanel Spacing="4" Margin="0,0,6,0">
                                    <TextBlock Text="Trigger" Classes="label" />
                                    <NumericUpDown Value="{Binding WeightTrigger}" Minimum="0" Maximum="5" Increment="0.1" FormatString="F2" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,6,0">
                                    <TextBlock Text="Deflexão" Classes="label" />
                                    <NumericUpDown Value="{Binding WeightDeflection}" Minimum="0" Maximum="5" Increment="0.1" FormatString="F2" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Recoil" Classes="label" />
                                    <NumericUpDown Value="{Binding WeightRecoil}" Minimum="0" Maximum="5" Increment="0.1" FormatString="F2" />
                                </StackPanel>
                            </Grid>

                            <!-- Manual cycle + safeguards -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Botão de ciclo (modo Manual)" Classes="label" />
                                <ComboBox ItemsSource="{Binding ButtonList}" SelectedItem="{Binding CycleButton}" MinWidth="200" />
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Cooldown entre flicks (ms)" Classes="label" />
                                    <NumericUpDown Value="{Binding ReFireCooldownMs}" Minimum="0" Maximum="2000" Increment="25" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Hold mínimo do gatilho (ms)" Classes="label" />
                                    <NumericUpDown Value="{Binding MinTriggerHoldMs}" Minimum="0" Maximum="500" Increment="5" />
                                </StackPanel>
                            </Grid>
                            <CheckBox Content="Disparar no primeiro frame (ADS snap)" IsChecked="{Binding FireOnPress}" />
                            <CheckBox Content="Disparar apenas 1 vez por toque (sem re-fire enquanto segurado)"
                                      IsChecked="{Binding FireOnce}"
                                      ToolTip.Tip="Desmarque para re-flicar a cada ReFireCooldownMs enquanto o gatilho está segurado (tracking de longa distância)." />
                        </StackPanel>
                    </Border>

                    <!-- ============ PROGRESSIVE RECOIL ============ -->
                    <Border Classes="section-panel" BorderBrush="#FF4444" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowProgressiveRecoilSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Progressive No-Recoil" FontWeight="SemiBold" FontSize="14" Foreground="#FF4444" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Compensação em 3 fases (início/meio/fim) baseada nas munições da arma. Transições usam smoothstep para não 'pular' entre fases." />

                            <StackPanel Spacing="4">
                                <TextBlock Text="Gatilho de tiro" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}" MinWidth="200" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Munições totais" Classes="label" />
                                    <NumericUpDown Value="{Binding PrTotalAmmo}" Minimum="3" Maximum="300" Increment="1" />
                                    <TextBlock Text="Ex: M4=30, RPD=100, SMG=47" FontSize="10" Foreground="#4A4F5A" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Tempo do pente cheio (ms)" Classes="label" />
                                    <NumericUpDown Value="{Binding PrFullMagDurationMs}" Minimum="500" Maximum="10000" Increment="100" />
                                    <TextBlock Text="2000–2500ms para rifles, 3000+ para LMGs" FontSize="10" Foreground="#4A4F5A" />
                                </StackPanel>
                            </Grid>

                            <!-- Phase 1 - Start -->
                            <Border Classes="section-panel" BorderBrush="#00FF9C" BorderThickness="2,0,0,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Fase 1 — Início (primeiro 1/3 do pente)" FontWeight="SemiBold" Foreground="#00FF9C" />
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Spacing="4" Margin="0,0,8,0">
                                            <TextBlock Text="Compensação X (horizontal)" Classes="label" />
                                            <NumericUpDown Value="{Binding PrStartCompX}" Minimum="-32767" Maximum="32767" Increment="500" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Compensação Y (vertical)" Classes="label" />
                                            <NumericUpDown Value="{Binding PrStartCompY}" Minimum="-32767" Maximum="32767" Increment="500" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Phase 2 - Mid -->
                            <Border Classes="section-panel" BorderBrush="#FFD93D" BorderThickness="2,0,0,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Fase 2 — Meio (segundo 1/3)" FontWeight="SemiBold" Foreground="#FFD93D" />
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Spacing="4" Margin="0,0,8,0">
                                            <TextBlock Text="Compensação X" Classes="label" />
                                            <NumericUpDown Value="{Binding PrMidCompX}" Minimum="-32767" Maximum="32767" Increment="500" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Compensação Y" Classes="label" />
                                            <NumericUpDown Value="{Binding PrMidCompY}" Minimum="-32767" Maximum="32767" Increment="500" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Phase 3 - End -->
                            <Border Classes="section-panel" BorderBrush="#FF6B6B" BorderThickness="2,0,0,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Fase 3 — Fim (último 1/3)" FontWeight="SemiBold" Foreground="#FF6B6B" />
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Spacing="4" Margin="0,0,8,0">
                                            <TextBlock Text="Compensação X" Classes="label" />
                                            <NumericUpDown Value="{Binding PrEndCompX}" Minimum="-32767" Maximum="32767" Increment="500" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Compensação Y" Classes="label" />
                                            <NumericUpDown Value="{Binding PrEndCompY}" Minimum="-32767" Maximum="32767" Increment="500" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="*,*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Easing entre fases" Classes="label" />
                                    <ComboBox ItemsSource="{Binding EasingKinds}" SelectedItem="{Binding PrPhaseEasing}" MinWidth="140" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Ruído anti-padrão" Classes="label" />
                                    <NumericUpDown Value="{Binding PrNoiseFactor}" Minimum="0" Maximum="1" Increment="0.05" FormatString="F2" />
                                    <TextBlock Text="0.15 = 15% recomendado" FontSize="10" Foreground="#4A4F5A" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Escala de sensibilidade" Classes="label" />
                                    <NumericUpDown Value="{Binding PrSensitivityScale}" Minimum="0.1" Maximum="5" Increment="0.1" FormatString="F1" />
                                    <TextBlock Text="2.0 = alta sens (metade comp, metade tempo)" FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Border Background="#1A1D22" CornerRadius="4" Padding="10,8">
                                <TextBlock FontSize="11" Foreground="#FFD93D" TextWrapping="Wrap"
                                           Text="Y negativo = puxa pra baixo (compensa recoil subindo). Comece com -3000/-5000/-7000 e ajuste. O smoothstep mistura suavemente entre as fases." />
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ============ TRACKING ASSIST ============ -->
                    <Border Classes="section-panel" BorderBrush="#00CCFF" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowTrackingAssistSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Tracking Assist" FontWeight="SemiBold" FontSize="14" Foreground="#00CCFF" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Enquanto você tracka um inimigo, adiciona movimentos orbitais no stick de mira que 'magnetizam' o aim assist do jogo ao alvo. Mais movimento = órbita maior = mais aim assist." />

                            <StackPanel Spacing="4">
                                <TextBlock Text="Gatilho de ativação" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}" MinWidth="200" />
                                <TextBlock Text="LT = ativa na mira (ADS). RT = ativa atirando. None = sempre." FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Analógico alvo" Classes="label" />
                                    <ComboBox ItemsSource="{Binding StickTargetKinds}" SelectedItem="{Binding TaTarget}" MinWidth="140" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Shape orbital" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ShapeKinds}" SelectedItem="{Binding TaShape}" MinWidth="140" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Raio base (parado)" Classes="label" />
                                    <NumericUpDown Value="{Binding TaBaseRadius}" Minimum="0.01" Maximum="0.5" Increment="0.01" FormatString="F2" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Raio máximo (full deflection)" Classes="label" />
                                    <NumericUpDown Value="{Binding TaMaxRadius}" Minimum="0.05" Maximum="1.0" Increment="0.05" FormatString="F2" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Período orbital (ms)" Classes="label" />
                                    <NumericUpDown Value="{Binding TaPeriodMs}" Minimum="30" Maximum="1000" Increment="10" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Threshold mínimo" Classes="label" />
                                    <NumericUpDown Value="{Binding TaDeflectionThreshold}" Minimum="0" Maximum="0.5" Increment="0.05" FormatString="F2" />
                                    <TextBlock Text="Abaixo disso = sem wobble" FontSize="10" Foreground="#4A4F5A" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Curva de escala" Classes="label" />
                                    <NumericUpDown Value="{Binding TaScaleCurve}" Minimum="0.1" Maximum="3.0" Increment="0.1" FormatString="F1" />
                                    <TextBlock Text="&lt;1 = agressivo, &gt;1 = gradual" FontSize="10" Foreground="#4A4F5A" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Intensidade" Classes="label" />
                                    <NumericUpDown Value="{Binding TaIntensityMul}" Minimum="0.1" Maximum="3.0" Increment="0.1" FormatString="F1" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <CheckBox Content="Horário" IsChecked="{Binding TaClockwise}" />
                            </StackPanel>

                            <Border Background="#0D2233" CornerRadius="6" Padding="12,10" Margin="0,4,0,0">
                                <StackPanel Spacing="6">
                                    <CheckBox Content="Órbita livre (sem precisar mover o stick)"
                                              IsChecked="{Binding TaFreeOrbit}"
                                              FontWeight="SemiBold" Foreground="#00CCFF" />
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#8A8F9A"
                                               Text="Quando ativado, o macro orbita sozinho usando o raio base mesmo sem input no analógico. Combine com TriggerSource=None e sem botão de ativação para um assist passivo permanente na câmera. Se mover o stick, o raio escala normalmente." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ============ AUTO FIRE + NO RECOIL ============ -->
                    <Border Classes="section-panel" BorderBrush="#FF8C42" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowAutoFireNoRecoilSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Auto Fire + No Recoil" FontWeight="SemiBold" FontSize="14" Foreground="#FF8C42" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Disparo rápido automático com compensação de recoil por arma. Configura intervalo de tiro + compensação X/Y." />
                            <StackPanel Spacing="4">
                                <TextBlock Text="Gatilho" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}" MinWidth="200" />
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Intervalo de tiro (ms)" Classes="label" />
                                    <NumericUpDown Value="{Binding MacroIntervalMs}" Minimum="10" Maximum="500" Increment="10" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Randomização" Classes="label" />
                                        <Slider Value="{Binding MacroRandomization}" Minimum="0" Maximum="1"
                                            ToolTip.Placement="Top"
                                            ToolTip.ShowDelay="0"
                                            ToolTip.Tip="{Binding MacroRandomization, StringFormat='Randomization {0:P0}'}" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Compensação X" Classes="label" />
                                    <NumericUpDown Value="{Binding RecoilCompensationX}" Minimum="-32767" Maximum="32767" Increment="500" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Compensação Y" Classes="label" />
                                    <NumericUpDown Value="{Binding RecoilCompensationY}" Minimum="-32767" Maximum="32767" Increment="500" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Se a detecção de arma estiver ativa, os valores da arma detectada substituem os acima."
                                       FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- ============ INSTA DROP SHOT ============ -->
                    <Border Classes="section-panel" BorderBrush="#9C27B0" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowInstaDropShotSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Insta Drop Shot" FontWeight="SemiBold" FontSize="14" Foreground="#9C27B0" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Força o boneco a deitar instantaneamente ao ativar — segura o botão de agachar continuamente para pular o delay normal do jogo. Pode ser manual (botão) ou automático (ao atirar)." />
                            <StackPanel Spacing="4">
                                <TextBlock Text="Botão de agachar/deitar" Classes="label" />
                                <ComboBox ItemsSource="{Binding ButtonList}" SelectedItem="{Binding CrouchButton}" MinWidth="200" />
                                <TextBlock Text="Padrão: B (○). Escolha o botão que seu jogo usa para agachar/deitar."
                                           FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Text="Configure o botão de ativação acima para manual, ou use Toggle Mode."
                                       FontSize="11" Foreground="#FFD93D" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- ============ JUMP SHOT ============ -->
                    <Border Classes="section-panel" BorderBrush="#4CAF50" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowJumpShotSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Jump Shot" FontWeight="SemiBold" FontSize="14" Foreground="#4CAF50" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="O personagem pula automaticamente quando você mira ou atira. Útil para bunny hop durante combate." />
                            <StackPanel Spacing="4">
                                <TextBlock Text="Gatilho (quando pular)" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}" MinWidth="200" />
                                <TextBlock Text="LT = pula ao mirar. RT = pula ao atirar." FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Botão de pulo" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ButtonList}" SelectedItem="{Binding JumpButton}" MinWidth="140" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Intervalo entre pulos (ms)" Classes="label" />
                                    <NumericUpDown Value="{Binding JumpIntervalMs}" Minimum="100" Maximum="2000" Increment="50" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ============ STRAFE SHOT ============ -->
                    <Border Classes="section-panel" BorderBrush="#2196F3" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowStrafeShotSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Strafe Shot" FontWeight="SemiBold" FontSize="14" Foreground="#2196F3" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Enquanto atira, o personagem vai para esquerda e direita automaticamente — dificulta o inimigo acertar." />
                            <StackPanel Spacing="4">
                                <TextBlock Text="Gatilho" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}" MinWidth="200" />
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Amplitude (0..1)" Classes="label" />
                                    <NumericUpDown Value="{Binding StrafeAmplitude}" Minimum="0.1" Maximum="1.0" Increment="0.05" FormatString="F2" />
                                    <TextBlock Text="Quanto o stick move pro lado. 0.6 = 60% do máximo." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Velocidade (ms por lado)" Classes="label" />
                                    <NumericUpDown Value="{Binding StrafeIntervalMs}" Minimum="30" Maximum="500" Increment="10" />
                                    <TextBlock Text="Menor = mais rápido. 120ms = ~4 strafes/s por lado." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ============ HOLD BREATH ============ -->
                    <Border Classes="section-panel" BorderBrush="#607D8B" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowHoldBreathSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Hold Breath" FontWeight="SemiBold" FontSize="14" Foreground="#607D8B" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Segura a respiração da sniper automaticamente enquanto mira — pressiona e segura L3 ou R3 enquanto o gatilho estiver ativo." />
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Botão de segurar respiração" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ButtonList}" SelectedItem="{Binding BreathButton}" MinWidth="140" />
                                    <TextBlock Text="L3 (LeftThumb) ou R3 (RightThumb) — depende do jogo." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Gatilho (quando segurar)" Classes="label" />
                                    <ComboBox ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}" MinWidth="140" />
                                    <TextBlock Text="LT = segura ao mirar (ADS). RT = segura ao atirar." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ============ SLIDE CANCEL ============ -->
                    <Border Classes="section-panel" BorderBrush="#FF5722" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowSlideCancelSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Slide Cancel" FontWeight="SemiBold" FontSize="14" Foreground="#FF5722" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Detecta quando você fez slide e cancela automaticamente após X ms — re-pressiona o botão de slide/agachar para cancelar a animação." />
                            <Grid ColumnDefinitions="*,*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Botão de slide" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ButtonList}" SelectedItem="{Binding SlideButton}" MinWidth="120" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Delay do cancel (ms)" Classes="label" />
                                    <NumericUpDown Value="{Binding SlideCancelDelayMs}" Minimum="50" Maximum="500" Increment="10" />
                                    <TextBlock Text="Tempo entre o slide e o cancel." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Botão de cancel" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ButtonList}" SelectedItem="{Binding SlideCancelButton}" MinWidth="120" />
                                    <TextBlock Text="Mesmo botão = re-press." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ============ FAST DROP ============ -->
                    <Border Classes="section-panel" BorderBrush="#E91E63" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowFastDropSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Fast Drop" FontWeight="SemiBold" FontSize="14" Foreground="#E91E63" />
                            <TextBlock Classes="label" TextWrapping="Wrap" Foreground="#8A8F9A"
                                       Text="Ao mirar/atirar, segura o botão de agachar ao mesmo tempo — o boneco deita enquanto atira. Soltar o gatilho = para de agachar." />
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Botão de agachar" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ButtonList}" SelectedItem="{Binding CrouchButton}" MinWidth="160" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Gatilho" Classes="label" />
                                    <ComboBox ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}" MinWidth="160" />
                                    <TextBlock Text="LT = deita ao mirar. RT = deita ao atirar." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ============ CROWBAR ============ -->
                    <Border Classes="section-panel" BorderBrush="#FF9800" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowCrowBarSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="CrowBar — Anti-Recoil Cooperativo" FontWeight="SemiBold" FontSize="14" Foreground="#FF9800" />
                            <Border Background="#1A1500" CornerRadius="6" Padding="10" BorderBrush="#332A00" BorderThickness="1">
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FFB74D"
                                           Text="Mecânica CrowBar: amplifica o controle manual de recoil do jogador com um valor fixo HTG. Quanto mais você puxa o analógico para baixo, mais a compensação aumenta automaticamente. Modo Rapido = 40% assist (você faz 60%). Modo Padrao = 90% assist (sistema faz quase tudo)." />
                            </Border>

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <!-- Row 0: Mode + HTG -->
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Modo" Classes="label" />
                                    <ComboBox ItemsSource="{Binding CrowBarModes}" SelectedItem="{Binding CrowBarMode}" MinWidth="140" />
                                    <TextBlock Text="Rapido = 40% assist | Padrao = 90% assist" FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Valor HTG Base" Classes="label" />
                                    <NumericUpDown Value="{Binding CrowBarBaseHtg}" Minimum="1" Maximum="50" Increment="1" />
                                    <TextBlock Text="Valor fixo de compensação (padrão 16)." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Row 1: Assist Factor + Deflection Threshold -->
                                <StackPanel Grid.Row="1" Spacing="4" Margin="0,8,8,0">
                                    <TextBlock Text="Fator de Assist" Classes="label" />
                                    <NumericUpDown Value="{Binding CrowBarAssistFactor}" Minimum="0.05" Maximum="1.0" Increment="0.05" FormatString="P0" />
                                    <TextBlock Text="% da compensação automática (0.40 = 40%)." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="0,8,0,0">
                                    <TextBlock Text="Limiar de Deflexão" Classes="label" />
                                    <NumericUpDown Value="{Binding CrowBarDeflectionThreshold}" Minimum="0.0" Maximum="0.5" Increment="0.01" FormatString="F2" />
                                    <TextBlock Text="Movimento mínimo do stick para ativar." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Row 2: Curve + Max Comp -->
                                <StackPanel Grid.Row="2" Spacing="4" Margin="0,8,8,0">
                                    <TextBlock Text="Curva de Deflexão" Classes="label" />
                                    <NumericUpDown Value="{Binding CrowBarDeflectionCurve}" Minimum="0.1" Maximum="3.0" Increment="0.1" FormatString="F1" />
                                    <TextBlock Text="1.0 = linear. &lt;1.0 = mais forte no início." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4" Margin="0,8,0,0">
                                    <TextBlock Text="Compensação Máxima" Classes="label" />
                                    <NumericUpDown Value="{Binding CrowBarMaxCompensation}" Minimum="1000" Maximum="32767" Increment="500" />
                                    <TextBlock Text="Limite da compensação por frame." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Row 3: Noise + HTG Scale Padrao -->
                                <StackPanel Grid.Row="3" Spacing="4" Margin="0,8,8,0">
                                    <TextBlock Text="Fator de Ruído" Classes="label" />
                                    <NumericUpDown Value="{Binding CrowBarNoiseFactor}" Minimum="0.0" Maximum="1.0" Increment="0.05" FormatString="F2" />
                                    <TextBlock Text="Variação aleatória para naturalidade." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4" Margin="0,8,0,0">
                                    <TextBlock Text="Escala HTG (Padrao)" Classes="label" />
                                    <NumericUpDown Value="{Binding CrowBarHtgScalePadrao}" Minimum="1.0" Maximum="2.0" Increment="0.025" FormatString="F3" />
                                    <TextBlock Text="16 x 1.125 = 18 efetivo. Só no modo Padrao." FontSize="10" Foreground="#4A4F5A" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <!-- Trigger Source -->
                            <StackPanel Spacing="4" Margin="0,4,0,0">
                                <TextBlock Text="Gatilho (disparo)" Classes="label" />
                                <ComboBox ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}" MinWidth="160" />
                                <TextBlock Text="CrowBar só ativa quando este gatilho está pressionado (atirando)." FontSize="10" Foreground="#4A4F5A" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ============ CUSTOM SCRIPT EDITOR ============ -->
                    <Border Classes="section-panel" BorderBrush="#00E5FF" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowCustomScriptSettings}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Script Editor (Cronus Zen-Style)" FontWeight="SemiBold" FontSize="16" Foreground="#00E5FF" />
                            <Border Background="#001A1F" CornerRadius="6" Padding="10" BorderBrush="#003340" BorderThickness="1">
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#4DD0E1"
                                           Text="Crie macros personalizados passo a passo, como no Cronus Zen. Cada step executa uma ação: pressionar/soltar botão, mover eixo, aguardar, ou repetir. Steps sem Wait entre eles executam no mesmo frame (botões simultâneos)." />
                            </Border>

                            <!-- Script-level settings -->
                            <Grid ColumnDefinitions="*,*,*,*" Margin="0,4,0,0">
                                <StackPanel Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Modo de Ativação" Classes="label" />
                                    <ComboBox ItemsSource="{Binding ScriptTriggerKinds}" SelectedItem="{Binding ScriptTriggerMode}" MinWidth="120" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Velocidade" Classes="label" />
                                    <NumericUpDown Value="{Binding ScriptSpeedMultiplier}" Minimum="0.1" Maximum="10.0" Increment="0.1" FormatString="F1" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,8,0">
                                    <CheckBox IsChecked="{Binding ScriptAutoLoop}" Content="Auto Loop" Margin="0,18,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="4">
                                    <TextBlock Text="Descrição" Classes="label" />
                                    <TextBox Text="{Binding ScriptDescription}" Watermark="Ex: Rapid Fire + DropShot" />
                                </StackPanel>
                            </Grid>

                            <!-- Activation: TriggerSource + reminder about ActivationButton above -->
                            <Border Background="#001A12" CornerRadius="6" Padding="10" BorderBrush="#004D30" BorderThickness="1">
                                <Grid ColumnDefinitions="*,*">
                                    <StackPanel Spacing="4" Margin="0,0,10,0">
                                        <TextBlock Text="Gatilho de Ativação" FontWeight="SemiBold" Foreground="#00FF9C" FontSize="12" />
                                        <ComboBox ItemsSource="{Binding TriggerSources}"
                                                  SelectedItem="{Binding TriggerSource}"
                                                  MinWidth="160"
                                                  AutomationProperties.Name="Custom script trigger source" />
                                        <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#4A4F5A"
                                                   Text="None = só o botão acima ativa. RT = exige gatilho direito. LT = gatilho esquerdo." />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#001208" CornerRadius="4" Padding="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Botão de Ativação" FontWeight="SemiBold" Foreground="#00FF9C" FontSize="12" />
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#8A8F9A"
                                                       Text="Use o painel 'Activation' no topo para definir qual botão ativa este script (ex: RightBumper para Y-Y Cancel)." />
                                            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#FFD93D"
                                                       Text="Atualmente: nenhum botão = ativa sempre que o gatilho for pressionado." />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Step toolbar -->
                            <Border Background="#0D1B1F" CornerRadius="4" Padding="6">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Content="+ Press" Command="{Binding AddPressStepCommand}" Classes="accent" FontSize="11" Padding="8,4"
                                                ToolTip.Tip="Adicionar step: Pressionar botão" />
                                        <Button Content="- Release" Command="{Binding AddReleaseStepCommand}" FontSize="11" Padding="8,4"
                                                ToolTip.Tip="Adicionar step: Soltar botão" />
                                        <Button Content="~ Eixo" Command="{Binding AddAxisStepCommand}" FontSize="11" Padding="8,4"
                                                ToolTip.Tip="Adicionar step: Mover eixo analógico" />
                                        <Button Content="Wait" Command="{Binding AddScriptStepCommand}" FontSize="11" Padding="8,4"
                                                ToolTip.Tip="Adicionar step: Aguardar X ms" />
                                        <Border Width="1" Background="#1A3040" Margin="4,2" />
                                        <Button Content="Duplicar" Command="{Binding DuplicateScriptStepCommand}" FontSize="11" Padding="8,4" />
                                        <Button Content="Deletar" Command="{Binding DeleteScriptStepCommand}" Classes="danger" FontSize="11" Padding="8,4" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Content="Rapid Fire" Command="{Binding InsertRapidFireComboCommand}" FontSize="10" Padding="6,3"
                                                ToolTip.Tip="Inserir combo de rapid fire (RT press/release loop)" />
                                        <Button Content="DropShot" Command="{Binding InsertDropShotComboCommand}" FontSize="10" Padding="6,3"
                                                ToolTip.Tip="Inserir combo de drop shot (RT + B simultâneo)" />
                                        <Button Content="Y-Y Cancel" Command="{Binding InsertYYCancelComboCommand}" FontSize="10" Padding="6,3"
                                                ToolTip.Tip="Inserir combo Y-Y weapon swap cancel" />
                                        <Border Width="1" Background="#1A3040" Margin="4,2" />
                                        <Button Content="Limpar Tudo" Command="{Binding ClearAllScriptStepsCommand}" Classes="danger" FontSize="10" Padding="6,3" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Step list + detail editor side by side -->
                            <Grid ColumnDefinitions="*,280" MinHeight="250">
                                <!-- Left: Step list -->
                                <Border Background="#080E12" CornerRadius="4" Padding="4" Margin="0,0,6,0">
                                    <DockPanel>
                                        <!-- Move up/down -->
                                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0" HorizontalAlignment="Center">
                                            <Button Content="Move Up" Command="{Binding MoveScriptStepUpCommand}" FontSize="10" Padding="10,3" />
                                            <Button Content="Move Down" Command="{Binding MoveScriptStepDownCommand}" FontSize="10" Padding="10,3" />
                                            <TextBlock Text="{Binding ScriptSteps.Count, StringFormat='{}{0} steps'}"
                                                       Foreground="#4A4F5A" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0" />
                                        </StackPanel>

                                        <!-- Empty state -->
                                        <TextBlock Text="Nenhum step ainda.&#x0A;Use os botões acima para adicionar."
                                                   Foreground="#2A3A40" FontSize="11" TextAlignment="Center"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   IsVisible="{Binding !ScriptSteps.Count}" />

                                        <ListBox ItemsSource="{Binding ScriptSteps}"
                                                 SelectedItem="{Binding SelectedScriptStep}"
                                                 Background="Transparent">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="6,4" CornerRadius="3" Margin="0,1"
                                                            Opacity="1">
                                                        <Grid ColumnDefinitions="24,Auto,*">
                                                            <TextBlock Text="{Binding Index, StringFormat='#{0}'}"
                                                                       Foreground="#4A4F5A" FontSize="10"
                                                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                                                       VerticalAlignment="Center" />
                                                            <Border Grid.Column="1" Width="4" Height="14" CornerRadius="2" Margin="4,0,8,0"
                                                                    VerticalAlignment="Center">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding ActionColor}" />
                                                                </Border.Background>
                                                            </Border>
                                                            <TextBlock Grid.Column="2" Text="{Binding Summary}"
                                                                       FontSize="12" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                </Border>

                                <!-- Right: Selected step editor -->
                                <Border Grid.Column="1" Background="#0A1418" CornerRadius="4" Padding="10">
                                    <StackPanel Spacing="8"
                                                IsVisible="{Binding SelectedScriptStep, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <TextBlock Text="Editar Step" FontWeight="SemiBold" FontSize="13" Foreground="#00E5FF" />

                                        <!-- Action type -->
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="Ação" Classes="label" FontSize="11" />
                                            <ComboBox ItemsSource="{Binding ScriptActionKinds}"
                                                      SelectedItem="{Binding SelectedScriptStep.Action}" MinWidth="160" />
                                        </StackPanel>

                                        <!-- Button picker (for Press/Release) -->
                                        <StackPanel Spacing="3" IsVisible="{Binding SelectedScriptStep.ShowButton}">
                                            <TextBlock Text="Botão" Classes="label" FontSize="11" />
                                            <ComboBox ItemsSource="{Binding ButtonList}"
                                                      SelectedItem="{Binding SelectedScriptStep.Button}" MinWidth="160" />
                                        </StackPanel>

                                        <!-- Axis picker (for SetAxis/SetTrigger) -->
                                        <StackPanel Spacing="3" IsVisible="{Binding SelectedScriptStep.ShowAxis}">
                                            <TextBlock Text="Eixo" Classes="label" FontSize="11" />
                                            <ComboBox ItemsSource="{Binding AxisList}"
                                                      SelectedItem="{Binding SelectedScriptStep.Axis}" MinWidth="160" />
                                        </StackPanel>

                                        <!-- Value (for SetAxis/SetTrigger) -->
                                        <StackPanel Spacing="3" IsVisible="{Binding SelectedScriptStep.ShowValue}">
                                            <TextBlock Text="Valor" Classes="label" FontSize="11" />
                                            <NumericUpDown Value="{Binding SelectedScriptStep.Value}"
                                                           Minimum="-32767" Maximum="32767" Increment="1000" />
                                            <TextBlock Text="Eixo: -32767..32767 | Trigger: 0..255"
                                                       FontSize="9" Foreground="#3A4A50" />
                                        </StackPanel>

                                        <!-- Duration (for Wait) -->
                                        <StackPanel Spacing="3" IsVisible="{Binding SelectedScriptStep.ShowDuration}">
                                            <TextBlock Text="Duração (ms)" Classes="label" FontSize="11" />
                                            <NumericUpDown Value="{Binding SelectedScriptStep.DurationMs}"
                                                           Minimum="1" Maximum="10000" Increment="10" />
                                            <TextBlock Text="Tempo de espera antes do próximo step."
                                                       FontSize="9" Foreground="#3A4A50" />
                                        </StackPanel>

                                        <!-- Loop target (for LoopBack) -->
                                        <StackPanel Spacing="3" IsVisible="{Binding SelectedScriptStep.ShowLoopTarget}">
                                            <TextBlock Text="Voltar para Step #" Classes="label" FontSize="11" />
                                            <NumericUpDown Value="{Binding SelectedScriptStep.LoopTargetIndex}"
                                                           Minimum="0" Maximum="999" Increment="1" />
                                        </StackPanel>

                                        <!-- Repeat count (for LoopBack/LoopStart) -->
                                        <StackPanel Spacing="3" IsVisible="{Binding SelectedScriptStep.ShowRepeatCount}">
                                            <TextBlock Text="Repetições" Classes="label" FontSize="11" />
                                            <NumericUpDown Value="{Binding SelectedScriptStep.RepeatCount}"
                                                           Minimum="0" Maximum="9999" Increment="1" />
                                            <TextBlock Text="0 = infinito (enquanto botão pressionado)"
                                                       FontSize="9" Foreground="#3A4A50" />
                                        </StackPanel>

                                        <!-- Label -->
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="Comentário" Classes="label" FontSize="11" />
                                            <TextBox Text="{Binding SelectedScriptStep.Label}"
                                                     Watermark="opcional" FontSize="11" />
                                        </StackPanel>

                                        <!-- Disabled toggle -->
                                        <CheckBox IsChecked="{Binding SelectedScriptStep.Disabled}"
                                                  Content="Desativado (pular este step)" FontSize="11" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ============ TIMING (shared) ============ -->
                    <Border Classes="section-panel" BorderBrush="#4A4F5A" BorderThickness="3,0,0,0"
                            IsVisible="{Binding ShowTimingSettings}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Timing" FontWeight="SemiBold" FontSize="14" Foreground="#EAEAEA" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="Initial Delay (ms)" Classes="label" />
                                <NumericUpDown Value="{Binding MacroDelayMs}" Minimum="0" Maximum="5000"
                                               Increment="50"
                                               AutomationProperties.Name="Initial delay"
                                               ToolTip.Tip="How long to wait (in ms) after the activation button is pressed before the macro starts executing. Use this when a game has a small activation animation that must complete first (e.g. ADS delay)." />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </ScrollViewer>
            </DockPanel>
            </Panel>
        </Border>
    </Grid>
</UserControl>
