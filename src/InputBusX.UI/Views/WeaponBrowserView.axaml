<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InputBusX.UI.ViewModels"
             xmlns:domain="using:InputBusX.Domain.Entities"
             x:Class="InputBusX.UI.Views.WeaponBrowserView"
             x:DataType="vm:WeaponBrowserViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Header + Active weapon ──────────────────────────────────── -->
        <Border Grid.Row="0" Classes="card card-interactive" Padding="18,14" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto">

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Banco de Armas"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#EAEAEA" />
                    <TextBlock Text="Selecione a arma que está usando — o recoil será aplicado automaticamente"
                               FontSize="12" Foreground="#4A4F5A" />
                </StackPanel>

                <!-- Active weapon badge -->
                <Border Grid.Column="1"
                    Classes="pill pill-accent"
                        Background="#0D1A12"
                        BorderBrush="#00FF9C"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,10"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="2">
                        <TextBlock Text="ATIVA"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="#00FF9C" LetterSpacing="2"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveWeaponName}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#EAEAEA"
                                   HorizontalAlignment="Center" />
                        <Button Content="✕ Limpar"
                                Command="{Binding ClearWeaponCommand}"
                                Background="Transparent"
                                Foreground="#4A4F5A"
                                BorderThickness="0"
                                FontSize="10"
                                Padding="0"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding ActiveEntry,
                                    Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ── Filters ─────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,12">

            <!-- Game buttons -->
            <StackPanel Spacing="4">
                <TextBlock Text="JOGO" Classes="label" FontSize="10" />
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Margin="0,0,8,4"
                                    Padding="16,6"
                                    CornerRadius="6"
                                    FontWeight="SemiBold"
                                    FontSize="12"
                                    Command="{Binding DataContext.SelectGameCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Styles>
                                    <Style Selector="Button">
                                        <Setter Property="Background" Value="#15181D" />
                                        <Setter Property="Foreground" Value="#8A8F9A" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush" Value="#1E2228" />
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Category + Search row -->
            <Grid ColumnDefinitions="160,*">

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Margin="0,0,8,0"
                          HorizontalAlignment="Stretch"
                          Background="#0F1115"
                          Foreground="#EAEAEA"
                          BorderBrush="#1E2228" />

                <TextBox Grid.Column="1"
                         Text="{Binding SearchText}"
                         Watermark="🔍  Buscar arma..."
                         Background="#0F1115"
                         Foreground="#EAEAEA"
                         BorderBrush="#1E2228"
                         CornerRadius="6"
                         Padding="10,8" />

            </Grid>

        </StackPanel>

        <!-- ── Weapons list ─────────────────────────────────────────────── -->
        <Border Grid.Row="2"
            Classes="card card-interactive"
                Background="#0F1115"
                BorderBrush="#1E2228"
                BorderThickness="1"
                CornerRadius="8">

            <ScrollViewer>
                <StackPanel Margin="8" Spacing="6">

                    <!-- Empty state -->
                    <Border Background="#0D0F13" CornerRadius="6" Padding="20"
                            IsVisible="{Binding !Weapons.Count}">
                        <TextBlock Text="Nenhuma arma encontrada para este filtro."
                                   FontSize="12" Foreground="#3A3F4A"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <ItemsControl ItemsSource="{Binding Weapons}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="domain:WeaponLibraryEntry">
                                <Border Classes="item-card" Margin="0,0,0,2"
                                        CornerRadius="6"
                                        BorderThickness="1">
                                    <!-- Highlight active weapon -->
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Setter Property="Background" Value="#15181D" />
                                            <Setter Property="BorderBrush" Value="#1E2228" />
                                        </Style>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="#0D1A12" />
                                            <Setter Property="BorderBrush" Value="#00FF9C" />
                                        </Style>
                                    </Border.Styles>

                                    <Grid ColumnDefinitions="Auto,*,80,80,Auto"
                                          Margin="14,10">

                                        <!-- Category badge -->
                                        <Border Grid.Column="0"
                                                Background="#1E2228"
                                                CornerRadius="4"
                                                Padding="8,3"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="10"
                                                       Foreground="#8A8F9A"
                                                       FontWeight="SemiBold" />
                                        </Border>

                                        <!-- Name -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#EAEAEA"
                                                   VerticalAlignment="Center" />

                                        <!-- Recoil Y -->
                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="RECOIL Y"
                                                       FontSize="9" Foreground="#4A4F5A"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding RecoilCompensationY}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#FFD93D"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>

                                        <!-- Intensity -->
                                        <StackPanel Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="INTENSITY"
                                                       FontSize="9" Foreground="#4A4F5A"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Intensity, StringFormat='{}{0:F1}×'}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#8A8F9A"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>

                                        <!-- Activate button -->
                                        <Button Grid.Column="4"
                                                Content="▶  Ativar"
                                                Background="#00FF9C"
                                                Foreground="#0A0A0A"
                                                FontWeight="Bold"
                                                FontSize="12"
                                                CornerRadius="6"
                                                Padding="14,6"
                                                VerticalAlignment="Center"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.ActivateWeaponCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

        </Border>

    </Grid>

</UserControl>
