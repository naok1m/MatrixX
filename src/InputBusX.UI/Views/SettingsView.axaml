<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InputBusX.UI.ViewModels"
             x:Class="InputBusX.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Spacing="16">
            <StackPanel Spacing="2">
                <TextBlock Text="Config" Classes="eyebrow" />
                <TextBlock Text="General Settings" Classes="h1" />
            </StackPanel>

            <Border Classes="section-panel"
                    BorderThickness="3,1,1,1"
                    BorderBrush="#4DA3FF">
                <StackPanel Spacing="16">
                    <TextBlock Text="Performance" Classes="section-header" />
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Polling Rate (ms)" Classes="label" />
                            <TextBlock Text="Lower values feel more responsive, but can increase CPU usage."
                                       Classes="muted"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <NumericUpDown Grid.Column="1"
                                       Value="{Binding PollingRateMs}"
                                       Minimum="1"
                                       Maximum="100"
                                       FormatString="0"
                                       Width="120"
                                       Margin="16,0,0,0"
                                       VerticalAlignment="Top" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="section-panel"
                    BorderThickness="3,1,1,1"
                    BorderBrush="#58D68D">
                <StackPanel Spacing="16">
                    <TextBlock Text="Startup" Classes="section-header" />

                    <CheckBox IsChecked="{Binding AutoConnect}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Auto-connect on startup" />
                            <TextBlock Text="Start the input pipeline when the app opens."
                                       Classes="muted" />
                        </StackPanel>
                    </CheckBox>

                    <CheckBox IsChecked="{Binding StartMinimized}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Start minimized" />
                            <TextBlock Text="Open the app in the background without showing the window."
                                       Classes="muted" />
                        </StackPanel>
                    </CheckBox>
                </StackPanel>
            </Border>

            <Border Classes="section-panel"
                    BorderThickness="3,1,1,1"
                    BorderBrush="#A78BFA">
                <StackPanel Spacing="16">
                    <TextBlock Text="System Tray" Classes="section-header" />

                    <CheckBox IsChecked="{Binding MinimizeToTray}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Minimize to system tray" />
                            <TextBlock Text="Closing the window sends it to the tray instead of exiting."
                                       Classes="muted" />
                        </StackPanel>
                    </CheckBox>

                    <CheckBox IsChecked="{Binding ShowNotifications}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Show tray notifications" />
                            <TextBlock Text="Display Windows notifications for connection events and weapon detection."
                                       Classes="muted"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </CheckBox>
                </StackPanel>
            </Border>

            <Border Classes="section-panel"
                    BorderThickness="3,1,1,1"
                    BorderBrush="#E6B450">
                <StackPanel Spacing="16">
                    <TextBlock Text="Logging" Classes="section-header" />
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Log Level" Classes="label" />
                            <TextBlock Text="Controls how much detail is written to the log file."
                                       Classes="muted" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding LogLevels}"
                                  SelectedItem="{Binding LogLevel}"
                                  Width="160"
                                  Margin="16,0,0,0"
                                  VerticalAlignment="Top" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding SaveStatus}"
                               Foreground="#7EE0AA"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               IsVisible="{Binding SaveStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                    <Button Grid.Column="1"
                            Content="Save Settings"
                            Command="{Binding SaveCommand}"
                            Classes="accent"
                            MinWidth="132" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
