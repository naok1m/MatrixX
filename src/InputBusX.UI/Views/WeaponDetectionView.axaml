<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InputBusX.UI.ViewModels"
             xmlns:conv="using:InputBusX.UI.Converters"
             x:Class="InputBusX.UI.Views.WeaponDetectionView"
             x:DataType="vm:WeaponDetectionViewModel">

    <UserControl.Resources>
        <conv:BoolToBrushConverter x:Key="RunningBrush"
                                   TrueBrush="#FF6B6B"
                                   FalseBrush="#00FF9C" />
        <conv:BoolToStringConverter x:Key="RunLabel"
                                    TrueValue="⏹  Stop Detection"
                                    FalseValue="▶  Start Detection" />
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="0,0,4,0" Spacing="12">

            <!-- ── Header ─────────────────────────────────────────────── -->
            <Border Classes="card" Padding="18,14">
                <Grid ColumnDefinitions="*,Auto">

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Weapon Detection"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#EAEAEA" />
                        <TextBlock Text="Recognises your active weapon by matching the HUD name plate against reference captures (OpenCV TM_CCOEFF_NORMED)."
                                   FontSize="12" Foreground="#4A4F5A"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding ToggleDetectionCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            Background="{Binding IsRunning, Converter={StaticResource RunningBrush}}"
                            Content="{Binding IsRunning, Converter={StaticResource RunLabel}}"
                            Foreground="#0A0A0A"
                            CornerRadius="6"
                            FontWeight="SemiBold"
                            Padding="16,8"
                            VerticalAlignment="Center" />

                </Grid>
            </Border>

            <!-- ── Status ─────────────────────────────────────────────── -->
            <Border Classes="card section-panel"
                    BorderThickness="3,0,0,0"
                    BorderBrush="#00FF9C"
                    Padding="18,14">
                <Grid ColumnDefinitions="*,*">

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="CURRENT WEAPON"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#00FF9C" LetterSpacing="2" />
                        <TextBlock Text="{Binding CurrentWeaponName}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#EAEAEA" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="STATUS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#4A4F5A" LetterSpacing="2" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="12" Foreground="#8A8F9A"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                </Grid>
            </Border>

            <!-- ── Capture region ─────────────────────────────────────── -->
            <Border Classes="card section-panel"
                    BorderThickness="3,0,0,0"
                    BorderBrush="#00DDFF"
                    Padding="14,12">
                <StackPanel Spacing="10">

                    <TextBlock Text="CAPTURE REGION"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#00DDFF" LetterSpacing="2" />

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Coordinates of the HUD area where the game shows the weapon name. Tight regions match faster and more reliably."
                                   FontSize="11" Foreground="#4A4F5A" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                x:Name="BtnSelectRegion"
                                Content="⊕  Selecionar Área"
                                Background="#1E2228"
                                Foreground="#00FF9C"
                                BorderBrush="#00FF9C"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,6"
                                FontSize="12"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0" />
                    </Grid>

                    <!-- X / Y / W / H — equal columns, compact -->
                    <Grid ColumnDefinitions="*,*,*,*" >

                        <StackPanel Grid.Column="0" Spacing="3" Margin="0,0,6,0">
                            <TextBlock Text="X" Classes="label" FontSize="10" />
                            <NumericUpDown Value="{Binding CaptureX}"
                                           Minimum="0" Maximum="7680"
                                           FormatString="0" FontSize="12" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="3" Margin="0,0,6,0">
                            <TextBlock Text="Y" Classes="label" FontSize="10" />
                            <NumericUpDown Value="{Binding CaptureY}"
                                           Minimum="0" Maximum="4320"
                                           FormatString="0" FontSize="12" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="3" Margin="0,0,6,0">
                            <TextBlock Text="Width" Classes="label" FontSize="10" />
                            <NumericUpDown Value="{Binding CaptureWidth}"
                                           Minimum="10" Maximum="1920"
                                           FormatString="0" FontSize="12" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="3">
                            <TextBlock Text="Height" Classes="label" FontSize="10" />
                            <NumericUpDown Value="{Binding CaptureHeight}"
                                           Minimum="10" Maximum="1080"
                                           FormatString="0" FontSize="12" />
                        </StackPanel>

                    </Grid>

                    <!-- Interval + Threshold + buttons in one row -->
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

                        <StackPanel Grid.Column="0" Spacing="3" Margin="0,0,12,0">
                            <TextBlock Text="Interval (ms)" Classes="label" FontSize="10" />
                            <NumericUpDown Value="{Binding IntervalMs}"
                                           Minimum="50" Maximum="5000"
                                           FormatString="0"
                                           FontSize="12"
                                           Width="110" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="Match Threshold (0.00–1.00)"
                                       Classes="label" FontSize="10"
                                       ToolTip.Tip="Minimum normalized correlation needed to accept a match. 0.80 recommended; raise for stricter matching, lower if valid weapons are being rejected." />
                            <NumericUpDown Value="{Binding MatchThreshold}"
                                           Minimum="0.50" Maximum="1.00"
                                           Increment="0.01"
                                           FormatString="F2"
                                           FontSize="12"
                                           Width="110" />
                        </StackPanel>

                        <Button Grid.Column="3"
                                Content="🔍 Preview"
                                Command="{Binding PreviewCaptureCommand}"
                                IsEnabled="{Binding !IsBusy}"
                                Background="#1E2228"
                                Foreground="#00DDFF"
                                BorderBrush="#00DDFF"
                                BorderThickness="1"
                                CornerRadius="6"
                                FontSize="12"
                                Padding="12,6"
                                Margin="0,0,6,0"
                                VerticalAlignment="Bottom"
                                ToolTip.Tip="Capture a screenshot of the region to verify coordinates." />

                        <Button Grid.Column="4"
                                Content="Run Test"
                                Command="{Binding TestCaptureCommand}"
                                IsEnabled="{Binding !IsBusy}"
                                Classes="accent"
                                FontSize="12"
                                Padding="12,6"
                                VerticalAlignment="Bottom"
                                ToolTip.Tip="Runs a single detection pass and prints per-weapon correlation scores." />

                    </Grid>

                    <!-- Live preview image -->
                    <Border Background="#0D0F13"
                            CornerRadius="6"
                            Padding="12,10"
                            IsVisible="{Binding CapturePreviewVisible}">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="REGION PREVIEW"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#00DDFF" LetterSpacing="2"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Foreground="#4A4F5A"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="12"
                                        Padding="4,2"
                                        Command="{Binding HidePreviewCommand}" />
                            </Grid>
                            <Image Source="{Binding CapturePreview}"
                                   MaxHeight="120"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Left"
                                   RenderOptions.BitmapInterpolationMode="HighQuality" />
                        </StackPanel>
                    </Border>

                    <!-- Detection test result -->
                    <Border Background="#0D0F13"
                            CornerRadius="6"
                            Padding="12,10"
                            IsVisible="{Binding TestCaptureResult,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="DETECTION RESULT"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#FFD93D" LetterSpacing="2"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        x:Name="BtnCopyOcrResult"
                                        Content="⎘ Copy"
                                        FontSize="11"
                                        Foreground="#FFD93D"
                                        Background="Transparent"
                                        BorderBrush="#FFD93D"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,3" />
                            </Grid>
                            <!-- IsReadOnly TextBox: same look but text is selectable + Ctrl+C works -->
                            <TextBox Text="{Binding TestCaptureResult, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     FontSize="12"
                                     Foreground="#EAEAEA"
                                     CaretBrush="#EAEAEA"
                                     SelectionBrush="#2A4A7A"
                                     TextWrapping="Wrap"
                                     FontFamily="Cascadia Code,Consolas,Courier New"
                                     AcceptsReturn="True" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ── Weapons list ───────────────────────────────────────── -->
            <Border Classes="card" Padding="18,14">
                <StackPanel Spacing="12">

                    <!-- Header row -->
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="WEAPON PROFILES"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#B388FF" LetterSpacing="2" />
                            <TextBlock Text="Equip a weapon in-game, then click 📷 on its row to capture a reference. More references = more robust detection."
                                       FontSize="11" Foreground="#4A4F5A"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Open library picker -->
                        <Button Grid.Column="1"
                                Content="📚 Banco de Armas"
                                Command="{Binding OpenLibraryCommand}"
                                Background="#1E2228"
                                Foreground="#B388FF"
                                BorderBrush="#B388FF"
                                BorderThickness="1"
                                CornerRadius="6"
                                FontWeight="SemiBold"
                                Padding="14,6"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center" />

                        <!-- Manual add -->
                        <Button Grid.Column="2"
                                Content="+ Adicionar"
                                Command="{Binding AddWeaponCommand}"
                                Classes="accent"
                                Padding="14,6"
                                VerticalAlignment="Center" />
                    </Grid>

                    <!-- Column labels -->
                    <Grid ColumnDefinitions="*,80,80,70,34" Margin="2,0">
                        <TextBlock Grid.Column="0" Text="NAME"
                                   Classes="label" FontSize="10" />
                        <TextBlock Grid.Column="1" Text="RECOIL X"
                                   Classes="label" FontSize="10" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="RECOIL Y"
                                   Classes="label" FontSize="10" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="INTENSITY"
                                   Classes="label" FontSize="10" HorizontalAlignment="Center" />
                    </Grid>

                    <!-- Weapon rows -->
                    <ItemsControl ItemsSource="{Binding Weapons}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:WeaponProfileItemViewModel">
                                <Border Background="#0D0F13"
                                        CornerRadius="6"
                                        Padding="8,6"
                                        Margin="0,0,0,6">
                                    <StackPanel Spacing="6">

                                        <!-- Row 1: main fields -->
                                        <Grid ColumnDefinitions="*,80,80,70,34">

                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Name}"
                                                     Margin="0,0,6,0"
                                                     Watermark="e.g. M4A1" />

                                            <NumericUpDown Grid.Column="1"
                                                           Value="{Binding RecoilCompensationX}"
                                                           Minimum="-32767" Maximum="32767"
                                                           Margin="0,0,6,0"
                                                           FormatString="0"
                                                           ShowButtonSpinner="False" />

                                            <NumericUpDown Grid.Column="2"
                                                           Value="{Binding RecoilCompensationY}"
                                                           Minimum="-32767" Maximum="32767"
                                                           Margin="0,0,6,0"
                                                           FormatString="0"
                                                           ShowButtonSpinner="False" />

                                            <NumericUpDown Grid.Column="3"
                                                           Value="{Binding Intensity}"
                                                           Minimum="0" Maximum="5"
                                                           Increment="0.1"
                                                           Margin="0,0,6,0"
                                                           FormatString="F2"
                                                           ShowButtonSpinner="False" />

                                            <Button Grid.Column="4"
                                                    Content="✕"
                                                    Foreground="#FF6B6B"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="4,0"
                                                    FontSize="13"
                                                    VerticalAlignment="Center"
                                                    CommandParameter="{Binding}"
                                                    Command="{Binding DataContext.RemoveWeaponCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}" />

                                        </Grid>

                                        <!-- Row 2: reference capture + rapid fire -->
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                              Margin="2,2,0,0">

                                            <Button Grid.Column="0"
                                                    Content="📷 Capturar Referência"
                                                    CommandParameter="{Binding}"
                                                    Command="{Binding DataContext.CaptureReferenceCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    IsEnabled="{Binding DataContext.IsBusy,
                                                                RelativeSource={RelativeSource AncestorType=UserControl},
                                                                Converter={x:Static BoolConverters.Not}}"
                                                    Background="#1E2228"
                                                    Foreground="#00FF9C"
                                                    BorderBrush="#00FF9C"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    FontSize="11"
                                                    Padding="10,4"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    ToolTip.Tip="Equip this weapon in-game first, then click to save a reference image of its HUD name plate." />

                                            <Button Grid.Column="1"
                                                    Content="🗑"
                                                    CommandParameter="{Binding}"
                                                    Command="{Binding DataContext.ClearReferencesCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    IsVisible="{Binding HasReferences}"
                                                    Background="Transparent"
                                                    Foreground="#FF6B6B"
                                                    BorderBrush="#FF6B6B"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    FontSize="11"
                                                    Padding="8,4"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center"
                                                    ToolTip.Tip="Delete every reference image for this weapon." />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ReferenceSummary}"
                                                       FontSize="11"
                                                       Foreground="#8A8F9A"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding RapidFireEnabled}"
                                                          Foreground="#FFD93D"
                                                          VerticalAlignment="Center">
                                                    <TextBlock Text="Rapid Fire"
                                                               FontSize="11"
                                                               Foreground="#FFD93D" />
                                                </CheckBox>
                                                <StackPanel Orientation="Horizontal" Spacing="6"
                                                            IsVisible="{Binding RapidFireEnabled}"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="ms:"
                                                               FontSize="11" Foreground="#8A8F9A"
                                                               VerticalAlignment="Center" />
                                                    <NumericUpDown Value="{Binding RapidFireIntervalMs}"
                                                                   Minimum="10" Maximum="500"
                                                                   FormatString="0"
                                                                   Width="80"
                                                                   ShowButtonSpinner="False" />
                                                </StackPanel>
                                            </StackPanel>

                                        </Grid>

                                        <!-- Row 3: per-weapon capture region override -->
                                        <StackPanel Spacing="4" Margin="2,2,0,0">
                                            <CheckBox IsChecked="{Binding UseCustomRegion}"
                                                      Foreground="#8A8F9A"
                                                      VerticalAlignment="Center">
                                                <TextBlock Text="Usar região de captura própria desta arma"
                                                           FontSize="11"
                                                           Foreground="#8A8F9A"
                                                           ToolTip.Tip="Quando marcado, a detecção captura esta arma da região abaixo em vez da região global. Útil quando armas diferentes têm nomes de larguras muito distintas." />
                                            </CheckBox>

                                            <Grid ColumnDefinitions="Auto,80,Auto,80,Auto,80,Auto,80"
                                                  IsVisible="{Binding UseCustomRegion}"
                                                  Margin="20,0,0,0">
                                                <TextBlock Grid.Column="0" Text="X:" FontSize="11"
                                                           Foreground="#8A8F9A" VerticalAlignment="Center"
                                                           Margin="0,0,4,0" />
                                                <NumericUpDown Grid.Column="1"
                                                               Value="{Binding CaptureX}"
                                                               Minimum="0" Maximum="9999"
                                                               FormatString="0"
                                                               ShowButtonSpinner="False"
                                                               Margin="0,0,10,0" />
                                                <TextBlock Grid.Column="2" Text="Y:" FontSize="11"
                                                           Foreground="#8A8F9A" VerticalAlignment="Center"
                                                           Margin="0,0,4,0" />
                                                <NumericUpDown Grid.Column="3"
                                                               Value="{Binding CaptureY}"
                                                               Minimum="0" Maximum="9999"
                                                               FormatString="0"
                                                               ShowButtonSpinner="False"
                                                               Margin="0,0,10,0" />
                                                <TextBlock Grid.Column="4" Text="W:" FontSize="11"
                                                           Foreground="#8A8F9A" VerticalAlignment="Center"
                                                           Margin="0,0,4,0" />
                                                <NumericUpDown Grid.Column="5"
                                                               Value="{Binding CaptureWidth}"
                                                               Minimum="1" Maximum="9999"
                                                               FormatString="0"
                                                               ShowButtonSpinner="False"
                                                               Margin="0,0,10,0" />
                                                <TextBlock Grid.Column="6" Text="H:" FontSize="11"
                                                           Foreground="#8A8F9A" VerticalAlignment="Center"
                                                           Margin="0,0,4,0" />
                                                <NumericUpDown Grid.Column="7"
                                                               Value="{Binding CaptureHeight}"
                                                               Minimum="1" Maximum="9999"
                                                               FormatString="0"
                                                               ShowButtonSpinner="False" />
                                            </Grid>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <Border Background="#0D0F13" CornerRadius="6" Padding="16"
                            IsVisible="{Binding !Weapons.Count}">
                        <TextBlock Text="No weapons configured — click '+ Adicionar' or pick from the library to begin."
                                   FontSize="12" Foreground="#3A3F4A"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <!-- Save -->
                    <Button Content="Save Settings"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            Classes="accent"
                            HorizontalAlignment="Right"
                            Padding="20,8" />

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
