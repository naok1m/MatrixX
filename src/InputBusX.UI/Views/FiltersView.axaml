<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InputBusX.UI.ViewModels"
             xmlns:controls="using:InputBusX.UI.Controls"
             x:Class="InputBusX.UI.Views.FiltersView"
             x:DataType="vm:FiltersViewModel">

    <!--
        Outer structure:
          Row 0 (Auto)  — page header
          Row 1 (24)    — structural gap (Avalonia 11.1 Grid has no RowSpacing)
          Row 2 (*)     — two-column content area

        Content columns:
          Col 0 (*)     — scrollable settings cards
          Col 1 (12)    — structural gap
          Col 2 (260)   — live preview panel
    -->
    <Grid RowDefinitions="Auto,24,*">

        <!-- ── Page header ─────────────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="Input Filters"
                   Classes="h1" />

        <!-- ── Two-column content ──────────────────────────────────────── -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,12,260">

            <!-- ── LEFT: scrollable settings ───────────────────────────── -->
            <ScrollViewer Grid.Column="0">
                <StackPanel Spacing="24">

                    <!-- ── Deadzone ────────────────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Deadzone" Classes="section-header" />

                            <!-- Left Stick: label+value row / 6px gap / slider row -->
                            <Grid RowDefinitions="Auto,6,Auto">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Left Stick"
                                               Classes="label"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Classes="label"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:P0}">
                                                <Binding Path="LeftStickDeadzone" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Grid.Row="2"
                                        Value="{Binding LeftStickDeadzone}"
                                        Minimum="0" Maximum="0.5"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding LeftStickDeadzone, StringFormat='Left Stick {0:P0}'}"
                                        ToolTip.ShowDelay="0"
                                        ToolTip.Placement="Top"
                                        AutomationProperties.Name="Left stick deadzone" />
                            </Grid>

                            <!-- Right Stick -->
                            <Grid RowDefinitions="Auto,6,Auto">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Right Stick"
                                               Classes="label"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Classes="label"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:P0}">
                                                <Binding Path="RightStickDeadzone" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Grid.Row="2"
                                        Value="{Binding RightStickDeadzone}"
                                        Minimum="0" Maximum="0.5"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding RightStickDeadzone, StringFormat='Right Stick {0:P0}'}"
                                        ToolTip.ShowDelay="0"
                                        ToolTip.Placement="Top"
                                        AutomationProperties.Name="Right stick deadzone" />
                            </Grid>

                            <!-- Trigger -->
                            <Grid RowDefinitions="Auto,6,Auto">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Trigger"
                                               Classes="label"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Classes="label"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:P0}">
                                                <Binding Path="TriggerDeadzone" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Grid.Row="2"
                                        Value="{Binding TriggerDeadzone}"
                                        Minimum="0" Maximum="0.5"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding TriggerDeadzone, StringFormat='Trigger {0:P0}'}"
                                        ToolTip.ShowDelay="0"
                                        ToolTip.Placement="Top"
                                        AutomationProperties.Name="Trigger deadzone" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Anti-Deadzone ───────────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Anti-Deadzone" Classes="section-header" />
                            <TextBlock Text="Adds minimum output to compensate for in-game deadzones."
                                       Classes="muted"
                                       TextWrapping="Wrap" />

                            <!-- Left Stick -->
                            <Grid RowDefinitions="Auto,6,Auto">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Left Stick"
                                               Classes="label"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Classes="label"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:P0}">
                                                <Binding Path="LeftStickAntiDeadzone" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Grid.Row="2"
                                        Value="{Binding LeftStickAntiDeadzone}"
                                        Minimum="0" Maximum="0.5"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding LeftStickAntiDeadzone, StringFormat='Left Stick {0:P0}'}"
                                        ToolTip.ShowDelay="0"
                                        ToolTip.Placement="Top"
                                        AutomationProperties.Name="Left stick anti-deadzone" />
                            </Grid>

                            <!-- Right Stick -->
                            <Grid RowDefinitions="Auto,6,Auto">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Right Stick"
                                               Classes="label"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Classes="label"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:P0}">
                                                <Binding Path="RightStickAntiDeadzone" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Grid.Row="2"
                                        Value="{Binding RightStickAntiDeadzone}"
                                        Minimum="0" Maximum="0.5"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding RightStickAntiDeadzone, StringFormat='Right Stick {0:P0}'}"
                                        ToolTip.ShowDelay="0"
                                        ToolTip.Placement="Top"
                                        AutomationProperties.Name="Right stick anti-deadzone" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Response Curve ──────────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Response Curve" Classes="section-header" />
                            <TextBlock Classes="muted" TextWrapping="Wrap">
                                <Run Text="1.0" Foreground="#00FF9C" />
                                <Run Text=" = linear  |  " />
                                <Run Text="&lt;1.0" Foreground="#00CFFF" />
                                <Run Text=" = more sensitive near center  |  " />
                                <Run Text="&gt;1.0" Foreground="#FF4D6A" />
                                <Run Text=" = less sensitive near center" />
                            </TextBlock>

                            <Grid RowDefinitions="Auto,6,Auto">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Exponent"
                                               Classes="label"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Classes="label"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:F2}">
                                                <Binding Path="ResponseCurveExponent" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Grid.Row="2"
                                        Value="{Binding ResponseCurveExponent}"
                                        Minimum="0.1" Maximum="4.0"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding ResponseCurveExponent, StringFormat='Exponent {0:F2}'}"
                                        ToolTip.ShowDelay="0"
                                        ToolTip.Placement="Top"
                                        AutomationProperties.Name="Response curve exponent" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Smoothing ───────────────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Smoothing" Classes="section-header" />

                            <CheckBox Content="Enable Smoothing"
                                      IsChecked="{Binding SmoothingEnabled}"
                                      AutomationProperties.Name="Enable input smoothing" />

                            <StackPanel Spacing="12" IsEnabled="{Binding SmoothingEnabled}">
                                <Grid RowDefinitions="Auto,6,Auto">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Factor"
                                                   Classes="label"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="label"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:P0}">
                                                    <Binding Path="SmoothingFactor" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                    <Slider Grid.Row="2"
                                            Value="{Binding SmoothingFactor}"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="{Binding SmoothingFactor, StringFormat='Factor {0:P0}'}"
                                            ToolTip.ShowDelay="0"
                                            ToolTip.Placement="Top"
                                            AutomationProperties.Name="Smoothing factor" />
                                </Grid>
                                <TextBlock Text="Higher = smoother but adds latency."
                                           Classes="muted" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Actions ─────────────────────────────────────── -->
                    <!-- Col 1 = spacer between the two buttons -->
                    <Grid ColumnDefinitions="*,Auto,10,Auto">
                        <Button Grid.Column="1"
                                Content="Reset Defaults"
                                Command="{Binding ResetDefaultsCommand}"
                                Classes="secondary"
                                AutomationProperties.Name="Reset filter settings to defaults" />
                        <Button Grid.Column="3"
                                Content="Apply"
                                Command="{Binding ApplyCommand}"
                                Classes="accent"
                                AutomationProperties.Name="Apply filter settings" />
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- ── RIGHT: live response curve preview ──────────────────── -->
            <Border Grid.Column="2"
                    Classes="card"
                    VerticalAlignment="Top">
                <StackPanel Spacing="12">

                    <!-- Header: status dot / 8px gap / title -->
                    <Grid ColumnDefinitions="Auto,8,*">
                        <Ellipse Grid.Column="0"
                                 Width="7" Height="7"
                                 Fill="#00FF9C"
                                 VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Live Preview"
                                   Classes="section-header"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Canvas border -->
                    <Border CornerRadius="12"
                            BorderBrush="#1F2533"
                            BorderThickness="1"
                            Background="#0B0E14"
                            Padding="8"
                            ClipToBounds="True">
                        <controls:ResponseCurveCanvas
                            Deadzone="{Binding LeftStickDeadzone}"
                            AntiDeadzone="{Binding LeftStickAntiDeadzone}"
                            Exponent="{Binding ResponseCurveExponent}"
                            Height="200" />
                    </Border>

                    <!-- Legend: each row is a Grid with swatch / 6px gap / label -->
                    <StackPanel Spacing="5">
                        <Grid ColumnDefinitions="Auto,6,*">
                            <Border Grid.Column="0"
                                    Width="18" Height="2"
                                    Background="#1D2235"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="Linear (1:1)"
                                       Classes="muted"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,6,*">
                            <Border Grid.Column="0"
                                    Width="18" Height="2"
                                    Background="#00FF9C"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="Your curve"
                                       Classes="muted"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,6,*">
                            <Border Grid.Column="0"
                                    Width="18" Height="2"
                                    Background="#111720"
                                    BorderBrush="#252B3F"
                                    BorderThickness="1"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="Deadzone"
                                       Classes="muted"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Classes="muted"
                               TextWrapping="Wrap"
                               Text="Showing left stick. Right stick uses the same exponent with its own deadzone settings." />

                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>
