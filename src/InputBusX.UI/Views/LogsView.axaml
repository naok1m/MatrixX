<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InputBusX.UI.ViewModels"
             xmlns:conv="using:InputBusX.UI.Converters"
             x:Class="InputBusX.UI.Views.LogsView"
             x:DataType="vm:LogsViewModel">

    <UserControl.Resources>
        <conv:LogLevelBrushConverter x:Key="LevelBrush" />
    </UserControl.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="12" Margin="0,0,0,16">
            <StackPanel Spacing="2">
                <TextBlock Text="Logs" Classes="eyebrow" />
                <TextBlock Text="System Logs" Classes="h1" />
            </StackPanel>

            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Text="{Binding FilterText}"
                         Watermark="Filter by message, category, or level"
                         AutomationProperties.Name="Log filter text" />
                <CheckBox Grid.Column="1"
                          Content="Auto-scroll"
                          IsChecked="{Binding AutoScroll}"
                          Margin="16,0"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Auto-scroll logs" />
                <Button Grid.Column="2"
                        Content="Clear"
                        Command="{Binding ClearLogsCommand}"
                        Classes="secondary"
                        AutomationProperties.Name="Clear all logs" />
            </Grid>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="No log entries yet. Start a connection to see activity."
                   Classes="muted"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   Margin="0,40,0,0"
                   IsVisible="{Binding !LogEntries.Count}" />

        <Border Classes="card-flush">
            <ListBox x:Name="LogListBox"
                     Margin="8"
                     ItemsSource="{Binding LogEntries}"
                     AutomationProperties.Name="Log entries list">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="Margin" Value="0,0,0,4" />
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="120,72,112,*">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss.fff}}"
                                       Classes="mono"
                                       Foreground="#7C8798" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Level}"
                                       Classes="mono"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Level, Converter={StaticResource LevelBrush}}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Category}"
                                       Classes="mono"
                                       Foreground="#7EE0AA"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Message}"
                                       Classes="mono"
                                       Foreground="#F4F6FA"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</UserControl>
