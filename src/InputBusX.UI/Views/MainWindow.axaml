<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:InputBusX.UI.ViewModels"
        xmlns:views="using:InputBusX.UI.Views"
        x:Class="InputBusX.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ReflexX"
        Width="1280" Height="800"
        MinWidth="1040" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#0B1018">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCurrentCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewItemCommand}" />
        <KeyBinding Gesture="Delete" Command="{Binding DeleteCurrentCommand}" />
    </Window.KeyBindings>

    <Panel>
        <Grid RowDefinitions="72,*,32">
            <Border Grid.Row="0"
                    Classes="topbar-shell"
                    Margin="16,12,16,8">
                <Grid ColumnDefinitions="Auto,*,Auto">

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                        <Border Width="32"
                                Height="32"
                                CornerRadius="8"
                                ClipToBounds="True"
                                Background="#0F1621">
                            <Image Source="avares://ReflexX/Assets/logo%20ReflexX.png"
                                   Stretch="UniformToFill" />
                        </Border>

                        <StackPanel Spacing="0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="ReflexX"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                                       Classes="muted"
                                       FontSize="11" />
                        </StackPanel>
                    </StackPanel>

                    <ListBox Grid.Column="1"
                             Margin="16,0"
                             SelectedIndex="{Binding SelectedTabIndex}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             AutomationProperties.Name="Main navigation">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBoxItem Classes="tab" Content="Home" />
                        <ListBoxItem Classes="tab" Content="Macros" />
                        <ListBoxItem Classes="tab" Content="Profiles" />
                        <ListBoxItem Classes="tab" Content="Curve" />
                        <ListBoxItem Classes="tab" Content="Weapons" />
                        <ListBoxItem Classes="tab" Content="Logs" />
                        <ListBoxItem Classes="tab" Content="Config" />
                    </ListBox>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <ComboBox Classes="topbar-chip"
                                  ItemsSource="{Binding GameProfiles}"
                                  SelectedItem="{Binding SelectedGameProfile}"
                                  Width="144"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  AutomationProperties.Name="Game profile selector" />

                        <Border Classes="pill pill-accent"
                                IsVisible="{Binding UpdateAvailable}"
                                ToolTip.Tip="A new version is ready. Click to download.">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Update"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#7EE0AA" />
                                <TextBlock Text="{Binding LatestVersion, StringFormat='v{0}'}"
                                           FontSize="12"
                                           Foreground="#A8EAC6" />
                            </StackPanel>
                        </Border>

                        <Border Classes="pill">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{Binding Dashboard.IsRunning, Converter={StaticResource BoolToConnFill}}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Dashboard.ConnectionStatus}"
                                           FontSize="12"
                                           MaxWidth="140"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Padding="16,8,16,16">
                <ContentControl Content="{Binding CurrentView}"
                                Opacity="{Binding ContentOpacity}">
                    <ContentControl.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity"
                                              Duration="0:0:0.18"
                                              Easing="CubicEaseOut" />
                        </Transitions>
                    </ContentControl.Transitions>
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:DashboardViewModel">
                            <views:DashboardView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:MacroEditorViewModel">
                            <views:MacroEditorView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ProfilesViewModel">
                            <views:ProfilesView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:FiltersViewModel">
                            <views:FiltersView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LogsViewModel">
                            <views:LogsView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:WeaponDetectionViewModel">
                            <views:WeaponDetectionView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsViewModel">
                            <views:SettingsView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>

            <Border Grid.Row="2"
                    Background="#0F1621"
                    BorderBrush="#283243"
                    BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Margin="16,0">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#4DA3FF" />
                        <TextBlock Text="Profile"
                                   Classes="muted"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Dashboard.ActiveProfileName}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="16,0"
                               Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="#AAB2C0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock Grid.Column="2"
                               Text="Precision in every input"
                               Classes="muted"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,56"
                CornerRadius="8"
                Padding="16,12"
                MaxWidth="380"
                IsVisible="{Binding Toast.IsVisible}"
                Background="{Binding Toast.Background}"
                BorderBrush="#283243"
                BorderThickness="1"
                ZIndex="100">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0"
                           Text="{Binding Toast.Icon}"
                           FontSize="16"
                           Foreground="{Binding Toast.Foreground}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           Text="{Binding Toast.Message}"
                           FontSize="13"
                           Foreground="{Binding Toast.Foreground}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Panel>
</Window>
