<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:InputBusX.UI.ViewModels"
        xmlns:views="using:InputBusX.UI.Views"
        xmlns:conv="using:InputBusX.UI.Converters"
        x:Class="InputBusX.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ReflexX"
        Width="1280" Height="800"
        MinWidth="1040" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#0B1018">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCurrentCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewItemCommand}" />
        <KeyBinding Gesture="Delete" Command="{Binding DeleteCurrentCommand}" />
    </Window.KeyBindings>

    <Window.Resources>
        <conv:IndexEqualsConverter x:Key="IndexEquals" />
    </Window.Resources>

    <Panel>
        <Grid RowDefinitions="84,*,32">
            <Border Grid.Row="0"
                    Classes="topbar-shell"
                    Margin="20,14,20,10">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto">

                    <Border Grid.Column="0"
                            Classes="brand-mark"
                            ClipToBounds="True"
                            VerticalAlignment="Center">
                        <Image Source="avares://ReflexX/Assets/logo%20ReflexX.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="24,0,0,0"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Main navigation">
                        <ToggleButton Classes="nav-tab"
                                      Content="HOME"
                                      Command="{Binding NavigateToCommand}"
                                      CommandParameter="Dashboard"
                                      IsChecked="{Binding SelectedTabIndex, Mode=OneWay, Converter={StaticResource IndexEquals}, ConverterParameter=0}" />
                        <ToggleButton Classes="nav-tab"
                                      Content="MACROS"
                                      Command="{Binding NavigateToCommand}"
                                      CommandParameter="Macros"
                                      IsChecked="{Binding SelectedTabIndex, Mode=OneWay, Converter={StaticResource IndexEquals}, ConverterParameter=1}" />
                        <ToggleButton Classes="nav-tab"
                                      Content="CURVE"
                                      Command="{Binding NavigateToCommand}"
                                      CommandParameter="Filters"
                                      IsChecked="{Binding SelectedTabIndex, Mode=OneWay, Converter={StaticResource IndexEquals}, ConverterParameter=2}" />
                        <ToggleButton Classes="nav-tab"
                                      Content="PROFILES"
                                      Command="{Binding NavigateToCommand}"
                                      CommandParameter="Profiles"
                                      IsChecked="{Binding SelectedTabIndex, Mode=OneWay, Converter={StaticResource IndexEquals}, ConverterParameter=3}" />
                        <ToggleButton Classes="nav-tab"
                                      Content="WEAPONS"
                                      Command="{Binding NavigateToCommand}"
                                      CommandParameter="Weapons"
                                      IsChecked="{Binding SelectedTabIndex, Mode=OneWay, Converter={StaticResource IndexEquals}, ConverterParameter=4}" />
                        <ToggleButton Classes="nav-tab"
                                      Content="LOGS"
                                      Command="{Binding NavigateToCommand}"
                                      CommandParameter="Logs"
                                      IsChecked="{Binding SelectedTabIndex, Mode=OneWay, Converter={StaticResource IndexEquals}, ConverterParameter=5}" />
                        <ToggleButton Classes="nav-tab"
                                      Content="SETTINGS"
                                      Command="{Binding NavigateToCommand}"
                                      CommandParameter="Settings"
                                      IsChecked="{Binding SelectedTabIndex, Mode=OneWay, Converter={StaticResource IndexEquals}, ConverterParameter=6}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <Border Classes="pill pill-accent"
                                IsVisible="{Binding UpdateAvailable}"
                                ToolTip.Tip="A new version is ready. Click to download.">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Update"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#7EE0AA" />
                                <TextBlock Text="{Binding LatestVersion, StringFormat='v{0}'}"
                                           FontSize="12"
                                           Foreground="#A8EAC6" />
                            </StackPanel>
                        </Border>

                        <ComboBox Classes="topbar-chip"
                                  ItemsSource="{Binding GameProfiles}"
                                  SelectedItem="{Binding SelectedGameProfile}"
                                  Width="156"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  AutomationProperties.Name="Game profile selector" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Padding="16,8,16,16">
                <ContentControl Content="{Binding CurrentView}"
                                Opacity="{Binding ContentOpacity}">
                    <ContentControl.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity"
                                              Duration="0:0:0.22"
                                              Easing="CubicEaseOut" />
                        </Transitions>
                    </ContentControl.Transitions>
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:DashboardViewModel">
                            <views:DashboardView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:MacroEditorViewModel">
                            <views:MacroEditorView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ProfilesViewModel">
                            <views:ProfilesView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:FiltersViewModel">
                            <views:FiltersView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LogsViewModel">
                            <views:LogsView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:WeaponDetectionViewModel">
                            <views:WeaponDetectionView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsViewModel">
                            <views:SettingsView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>

            <Border Grid.Row="2"
                    Background="#0F1621"
                    BorderBrush="#283243"
                    BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Margin="16,0">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#4DA3FF" />
                        <TextBlock Text="Profile"
                                   Classes="muted"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Dashboard.ActiveProfileName}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="16,0"
                               Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="#AAB2C0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock Grid.Column="2"
                               Text="Precision in every input"
                               Classes="muted"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,56"
                CornerRadius="8"
                Padding="16,12"
                MaxWidth="380"
                IsVisible="{Binding Toast.IsVisible}"
                Background="{Binding Toast.Background}"
                BorderBrush="#283243"
                BorderThickness="1"
                ZIndex="100">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0"
                           Text="{Binding Toast.Icon}"
                           FontSize="16"
                           Foreground="{Binding Toast.Foreground}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           Text="{Binding Toast.Message}"
                           FontSize="13"
                           Foreground="{Binding Toast.Foreground}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Panel>
</Window>
