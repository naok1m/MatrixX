<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:InputBusX.UI.ViewModels"
        xmlns:views="using:InputBusX.UI.Views"
        x:Class="InputBusX.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="MatrixX"
        Width="1280" Height="800"
        MinWidth="1100" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#06070C">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCurrentCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewItemCommand}" />
        <KeyBinding Gesture="Delete" Command="{Binding DeleteCurrentCommand}" />
    </Window.KeyBindings>

    <Panel>
    <Grid RowDefinitions="60,*,40">

        <!-- ═══════════════════════════════════════════════════════════════
             TOP NAV — logo + horizontal tabs + game chip + connection
            ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#0A0C12"
                BorderBrush="#1F2533"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="20,0">

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center">
                    <Border CornerRadius="8" Width="32" Height="32"
                            ClipToBounds="True"
                            BoxShadow="0 0 16 0 #6000FF95">
                        <Image Source="avares://MatrixX/Assets/matrixx-icon.png"
                               Width="32" Height="32"
                               Stretch="UniformToFill" />
                    </Border>
                    <TextBlock Text="MatrixX"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#F0F2F8"
                               VerticalAlignment="Center" />
                    <Border Background="#0A2218"
                            BorderBrush="#0000FF95"
                            BorderThickness="1"
                            CornerRadius="100"
                            Padding="6,1"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock FontSize="9" FontWeight="Bold"
                                   Foreground="#00FF95"
                                   LetterSpacing="1">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="v{0}">
                                    <Binding Path="AppVersion" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Horizontal tabs (centered) -->
                <ListBox Grid.Column="1"
                         SelectedIndex="{Binding SelectedTabIndex}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Stretch"
                         AutomationProperties.Name="Main navigation">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBoxItem Classes="tab" Content="Home" />
                    <ListBoxItem Classes="tab" Content="Macros" />
                    <ListBoxItem Classes="tab" Content="Profiles" />
                    <ListBoxItem Classes="tab" Content="Curve" />
                    <ListBoxItem Classes="tab" Content="Weapons" />
                    <ListBoxItem Classes="tab" Content="Logs" />
                    <ListBoxItem Classes="tab" Content="Config" />
                </ListBox>

                <!-- Right cluster: update banner + connection pill -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Spacing="10" VerticalAlignment="Center">

                    <!-- Update banner (only when available) -->
                    <Border Classes="pill pill-accent"
                            IsVisible="{Binding UpdateAvailable}"
                            ToolTip.Tip="A new version is ready. Click to download.">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="⬆" FontSize="11" Foreground="#00FF95" />
                            <TextBlock Text="Update" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#00FF95" />
                            <TextBlock Text="{Binding LatestVersion, StringFormat='v{0}'}"
                                       FontSize="11" Foreground="#00FF95" Opacity="0.7" />
                        </StackPanel>
                    </Border>

                    <!-- Connection pill -->
                    <Border Classes="pill">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7"
                                     Fill="{Binding Dashboard.IsRunning,
                                            Converter={StaticResource BoolToConnFill}}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Dashboard.ConnectionStatus}"
                                       FontSize="11"
                                       Foreground="#F0F2F8"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             CONTENT AREA
            ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Padding="24">
            <ContentControl Content="{Binding CurrentView}"
                            Opacity="{Binding ContentOpacity}">
                <ContentControl.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity"
                                          Duration="0:0:0.18"
                                          Easing="CubicEaseOut" />
                    </Transitions>
                </ContentControl.Transitions>
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:DashboardViewModel">
                        <views:DashboardView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:MacroEditorViewModel">
                        <views:MacroEditorView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:ProfilesViewModel">
                        <views:ProfilesView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:FiltersViewModel">
                        <views:FiltersView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:LogsViewModel">
                        <views:LogsView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:WeaponDetectionViewModel">
                        <views:WeaponDetectionView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:SettingsViewModel">
                        <views:SettingsView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             STATUS BAR (bottom dock — always visible)
            ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#0A0C12"
                BorderBrush="#1F2533"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="20,0">

                <!-- Left: profile + macros count -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Spacing="14" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="◉" FontSize="11" Foreground="#00B7FF" />
                        <TextBlock Classes="muted" Text="PROFILE" FontWeight="SemiBold"
                                   LetterSpacing="1" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Dashboard.ActiveProfileName}"
                                   FontSize="11" Foreground="#F0F2F8" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Center: live status text -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="#8B92A8"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <!-- Right: device + brand -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Spacing="14" VerticalAlignment="Center">
                    <TextBlock Classes="muted"
                               Text="MatrixX — Premium Controller Engine"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>

    <!-- ═══ Toast notification overlay ═══════════════════════════════════ -->
    <Border HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,24,56"
            CornerRadius="10"
            Padding="16,12"
            MaxWidth="380"
            IsVisible="{Binding Toast.IsVisible}"
            Background="{Binding Toast.Background}"
            BoxShadow="0 8 28 0 #80000000"
            ZIndex="100">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{Binding Toast.Icon}"
                       FontSize="16"
                       Foreground="{Binding Toast.Foreground}"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding Toast.Message}"
                       FontSize="13"
                       Foreground="{Binding Toast.Foreground}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Border>

    </Panel>
</Window>
