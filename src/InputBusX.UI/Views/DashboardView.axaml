<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InputBusX.UI.ViewModels"
             xmlns:conv="using:InputBusX.UI.Converters"
             x:Class="InputBusX.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Resources>
        <conv:BoolToBrushConverter x:Key="StatusBrush" />
        <conv:StickToCanvasConverter x:Key="StickToCanvas" CanvasSize="96" />
        <conv:PercentageConverter x:Key="TriggerHeight" MaxHeight="80" />
        <conv:BoolToStringConverter x:Key="ConnectLabel" TrueValue="Stop" FalseValue="Start" />
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="4">
            <!-- Header -->
            <TextBlock Text="Dashboard" Classes="section-header" FontSize="18" />

            <!-- Connection & Status Row -->
            <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,6">
                <Border Classes="card" Grid.Column="0" Padding="12,10">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                            <Ellipse Width="7" Height="7" Fill="#00FF9C" VerticalAlignment="Center" />
                            <TextBlock Text="Connection" FontSize="13" FontWeight="SemiBold" Foreground="#EAEAEA" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Classes="status-dot"
                                     Fill="{Binding IsRunning, Converter={StaticResource StatusBrush}}" />
                            <TextBlock Text="{Binding ConnectionStatus}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       Foreground="#CACACA" />
                        </StackPanel>
                        <Button Content="{Binding IsRunning, Converter={StaticResource ConnectLabel}}"
                                Command="{Binding ToggleConnectionCommand}"
                                IsEnabled="{Binding !IsConnecting}"
                                Classes="accent"
                                FontSize="12"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.Name="Toggle controller connection" />
                    </StackPanel>
                </Border>

                <Border Classes="card" Grid.Column="1" Padding="12,10">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                            <Ellipse Width="7" Height="7" Fill="#00DDFF" VerticalAlignment="Center" />
                            <TextBlock Text="Profile" FontSize="13" FontWeight="SemiBold" Foreground="#EAEAEA" />
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveProfileName}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#00FF9C"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Classes="card" Grid.Column="2" Padding="12,10">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                            <Ellipse Width="7" Height="7" Fill="#B388FF" VerticalAlignment="Center" />
                            <TextBlock Text="Devices" FontSize="13" FontWeight="SemiBold" Foreground="#EAEAEA" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding ConnectedDevices}"
                                      AutomationProperties.Name="Connected devices list">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#EAEAEA"
                                               FontSize="11" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No devices connected"
                                   IsVisible="{Binding !ConnectedDevices.Count}"
                                   Foreground="#4A4F5A" FontStyle="Italic" FontSize="11" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Input Visualizer -->
            <Border Classes="card" Padding="14,12">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <Ellipse Width="7" Height="7" Fill="#FFD93D" VerticalAlignment="Center" />
                        <TextBlock Text="Real-Time Input" FontSize="13" FontWeight="SemiBold" Foreground="#EAEAEA" />
                    </StackPanel>

                    <!-- Sticks + Triggers -->
                    <Grid ColumnDefinitions="*,Auto,*">
                        <!-- Left Stick -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="6">
                            <TextBlock Text="Left Stick" Classes="label" HorizontalAlignment="Center" />
                            <Border Width="106" Height="106" CornerRadius="53"
                                    Background="#1E2228" BorderBrush="#2A2D34" BorderThickness="2">
                                <Canvas Width="96" Height="96">
                                    <Line StartPoint="48,0" EndPoint="48,96" Stroke="#2A2D34" StrokeThickness="1" />
                                    <Line StartPoint="0,48" EndPoint="96,48" Stroke="#2A2D34" StrokeThickness="1" />
                                    <Ellipse Width="12" Height="12" Fill="#00FF9C"
                                             Canvas.Left="{Binding LeftStickX, Converter={StaticResource StickToCanvas}}"
                                             Canvas.Top="{Binding LeftStickY, Converter={StaticResource StickToCanvas}, ConverterParameter=invert}" />
                                </Canvas>
                            </Border>
                            <TextBlock HorizontalAlignment="Center" Foreground="#4A4F5A" FontSize="10">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="X:{0:F2} Y:{1:F2}">
                                        <Binding Path="LeftStickX" />
                                        <Binding Path="LeftStickY" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <!-- Triggers -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="LT" Classes="label" HorizontalAlignment="Center" />
                                <Border Width="26" Height="80" Background="#1E2228" CornerRadius="4">
                                    <Border VerticalAlignment="Bottom" Background="#FFD93D" CornerRadius="4"
                                            Height="{Binding LeftTrigger, Converter={StaticResource TriggerHeight}}" />
                                </Border>
                                <TextBlock Text="{Binding LeftTrigger, StringFormat={}{0:P0}}"
                                           FontSize="10" Foreground="#4A4F5A" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="RT" Classes="label" HorizontalAlignment="Center" />
                                <Border Width="26" Height="80" Background="#1E2228" CornerRadius="4">
                                    <Border VerticalAlignment="Bottom" Background="#FFD93D" CornerRadius="4"
                                            Height="{Binding RightTrigger, Converter={StaticResource TriggerHeight}}" />
                                </Border>
                                <TextBlock Text="{Binding RightTrigger, StringFormat={}{0:P0}}"
                                           FontSize="10" Foreground="#4A4F5A" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Stick -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="6">
                            <TextBlock Text="Right Stick" Classes="label" HorizontalAlignment="Center" />
                            <Border Width="106" Height="106" CornerRadius="53"
                                    Background="#1E2228" BorderBrush="#2A2D34" BorderThickness="2">
                                <Canvas Width="96" Height="96">
                                    <Line StartPoint="48,0" EndPoint="48,96" Stroke="#2A2D34" StrokeThickness="1" />
                                    <Line StartPoint="0,48" EndPoint="96,48" Stroke="#2A2D34" StrokeThickness="1" />
                                    <Ellipse Width="12" Height="12" Fill="#00DDFF"
                                             Canvas.Left="{Binding RightStickX, Converter={StaticResource StickToCanvas}}"
                                             Canvas.Top="{Binding RightStickY, Converter={StaticResource StickToCanvas}, ConverterParameter=invert}" />
                                </Canvas>
                            </Border>
                            <TextBlock HorizontalAlignment="Center" Foreground="#4A4F5A" FontSize="10">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="X:{0:F2} Y:{1:F2}">
                                        <Binding Path="RightStickX" />
                                        <Binding Path="RightStickY" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- RAW / OUTPUT labels -->
                    <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                        <TextBlock Grid.Column="0" Text="RAW IN"
                                   FontSize="10" Foreground="#4A4F5A" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="OUTPUT (after macros)"
                                   FontSize="10" Foreground="#00FF9C" HorizontalAlignment="Center" />
                    </Grid>

                    <!-- Buttons grid — 22px cells -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,2,0,0">
                        <!-- DPad RAW -->
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="D-Pad" Classes="label" HorizontalAlignment="Center" />
                            <Grid RowDefinitions="22,22,22" ColumnDefinitions="22,22,22" Width="66" Height="66">
                                <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator"
                                         Fill="{Binding DpadUp, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator"
                                         Fill="{Binding DpadLeft, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator"
                                         Fill="{Binding DpadRight, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator"
                                         Fill="{Binding DpadDown, Converter={StaticResource StatusBrush}}" />
                            </Grid>
                        </StackPanel>

                        <!-- Face Buttons RAW -->
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Buttons" Classes="label" HorizontalAlignment="Center" />
                            <Grid RowDefinitions="22,22,22" ColumnDefinitions="22,22,22" Width="66" Height="66">
                                <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator"
                                         Fill="{Binding ButtonY, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator"
                                         Fill="{Binding ButtonX, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator"
                                         Fill="{Binding ButtonB, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator"
                                         Fill="{Binding ButtonA, Converter={StaticResource StatusBrush}}" />
                            </Grid>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Width="1" Background="#1E2228" Margin="2,8" />

                        <!-- DPad OUT -->
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="D-Pad OUT" FontSize="10" Foreground="#00FF9C" HorizontalAlignment="Center" />
                            <Grid RowDefinitions="22,22,22" ColumnDefinitions="22,22,22" Width="66" Height="66">
                                <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator"
                                         Fill="{Binding OutDpadUp, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator"
                                         Fill="{Binding OutDpadLeft, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator"
                                         Fill="{Binding OutDpadRight, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator"
                                         Fill="{Binding OutDpadDown, Converter={StaticResource StatusBrush}}" />
                            </Grid>
                        </StackPanel>

                        <!-- Face Buttons OUT -->
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Buttons OUT" FontSize="10" Foreground="#00FF9C" HorizontalAlignment="Center" />
                            <Grid RowDefinitions="22,22,22" ColumnDefinitions="22,22,22" Width="66" Height="66">
                                <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator"
                                         Fill="{Binding OutButtonY, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator"
                                         Fill="{Binding OutButtonX, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator"
                                         Fill="{Binding OutButtonB, Converter={StaticResource StatusBrush}}" />
                                <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator"
                                         Fill="{Binding OutButtonA, Converter={StaticResource StatusBrush}}" />
                            </Grid>
                        </StackPanel>

                        <!-- Shoulders + Menu -->
                        <StackPanel Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="Shoulders" Classes="label" HorizontalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Padding="6,3" CornerRadius="4"
                                        Background="{Binding ButtonLB, Converter={StaticResource StatusBrush}}">
                                    <TextBlock Text="LB" FontSize="10" Foreground="#0A0A0A" FontWeight="Bold" />
                                </Border>
                                <Border Padding="6,3" CornerRadius="4"
                                        Background="{Binding ButtonRB, Converter={StaticResource StatusBrush}}">
                                    <TextBlock Text="RB" FontSize="10" Foreground="#0A0A0A" FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <Border Padding="5,2" CornerRadius="3"
                                        Background="{Binding ButtonBack, Converter={StaticResource StatusBrush}}">
                                    <TextBlock Text="Back" FontSize="9" Foreground="#0A0A0A" />
                                </Border>
                                <Border Padding="5,2" CornerRadius="3"
                                        Background="{Binding ButtonStart, Converter={StaticResource StatusBrush}}">
                                    <TextBlock Text="Start" FontSize="9" Foreground="#0A0A0A" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
