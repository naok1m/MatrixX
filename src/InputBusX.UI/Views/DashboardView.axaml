<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InputBusX.UI.ViewModels"
             xmlns:conv="using:InputBusX.UI.Converters"
             x:Class="InputBusX.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Resources>
        <conv:BoolToBrushConverter x:Key="StatusBrush" />
        <conv:BoolToBrushConverter x:Key="GreenGrayBrush"
                                   TrueBrush="#00FF95"
                                   FalseBrush="#2A3345" />
        <conv:StickToCanvasConverter x:Key="StickToCanvas" CanvasSize="96" />
        <conv:PercentageConverter x:Key="TriggerHeight" MaxHeight="88" />
        <conv:BoolToStringConverter x:Key="ConnectLabel" TrueValue="Stop" FalseValue="Start" />
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="0">

            <!-- ═══ Page header ═══════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="HOME" Classes="eyebrow" />
                    <TextBlock Text="Dashboard" Classes="h1" />
                </StackPanel>
                <!-- Connection badge top-right -->
                <Border Grid.Column="1" Classes="pill" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                 Fill="{Binding IsRunning, Converter={StaticResource GreenGrayBrush}}" />
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   FontSize="11" Foreground="#F0F2F8"
                                   VerticalAlignment="Center"
                                   MaxWidth="220" TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Stat row ═══════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,*,*" Margin="0" HorizontalAlignment="Stretch">
                <!-- Connection card -->
                <Border Classes="stat-card card-interactive" Grid.Column="0" Margin="0,0,8,0">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                     Fill="{Binding IsRunning, Converter={StaticResource GreenGrayBrush}}" />
                            <TextBlock Text="CONEXÃO" Classes="eyebrow" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   FontSize="12" Foreground="#8B92A8"
                                   TextWrapping="Wrap" />
                        <Button Content="{Binding IsRunning, Converter={StaticResource ConnectLabel}}"
                                Command="{Binding ToggleConnectionCommand}"
                                IsEnabled="{Binding !IsConnecting}"
                                Classes="accent"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.Name="Toggle controller connection" />
                    </StackPanel>
                </Border>

                <!-- Profile card -->
                <Border Classes="stat-card card-interactive" Grid.Column="1" Margin="0,0,8,0">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="#00B7FF" />
                            <TextBlock Text="PERFIL ATIVO" Classes="eyebrow" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveProfileName}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#00FF95"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Devices card -->
                <Border Classes="stat-card card-interactive" Grid.Column="2">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="#FFB547" />
                            <TextBlock Text="DISPOSITIVOS" Classes="eyebrow" VerticalAlignment="Center" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding ConnectedDevices}"
                                      AutomationProperties.Name="Connected devices list">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#F0F2F8"
                                               FontSize="12" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Nenhum dispositivo"
                                   IsVisible="{Binding !ConnectedDevices.Count}"
                                   Foreground="#4A5066" FontStyle="Italic" FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Live Input Visualizer ══════════════════════════════════════ -->
            <Border Classes="card card-interactive" Padding="20">
                <StackPanel Spacing="18">

                    <!-- Section title -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#FFB547" VerticalAlignment="Center" />
                            <TextBlock Text="Input em Tempo Real" FontWeight="SemiBold" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="#4A5066" VerticalAlignment="Center" />
                                <TextBlock Text="RAW IN" FontSize="10" Foreground="#4A5066" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="#00FF95" VerticalAlignment="Center" />
                                <TextBlock Text="OUTPUT" FontSize="10" Foreground="#00FF95" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Sticks + Triggers row -->
                    <Grid ColumnDefinitions="*,Auto,*">

                        <!-- Left Stick -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="Left Stick" Classes="label" HorizontalAlignment="Center" />
                            <Border Width="114" Height="114" CornerRadius="57"
                                    Background="#080B11"
                                    BorderBrush="#1F2533" BorderThickness="2"
                                    BoxShadow="inset 0 2 12 0 #40000000">
                                <Canvas Width="96" Height="96">
                                    <!-- Crosshairs -->
                                    <Line StartPoint="48,4" EndPoint="48,92" Stroke="#1F2533" StrokeThickness="1" />
                                    <Line StartPoint="4,48" EndPoint="92,48" Stroke="#1F2533" StrokeThickness="1" />
                                    <!-- Center ring -->
                                    <Ellipse Width="8" Height="8" Fill="Transparent"
                                             Stroke="#2A3345" StrokeThickness="1"
                                             Canvas.Left="44" Canvas.Top="44" />
                                    <!-- Stick dot with glow -->
                                    <Ellipse Width="14" Height="14"
                                             Fill="#00FF95"
                                             Canvas.Left="{Binding LeftStickX, Converter={StaticResource StickToCanvas}}"
                                             Canvas.Top="{Binding LeftStickY, Converter={StaticResource StickToCanvas}, ConverterParameter=invert}" />
                                </Canvas>
                            </Border>
                            <TextBlock HorizontalAlignment="Center" FontSize="10"
                                       Classes="mono" Foreground="#4A5066">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="X:{0:F2}  Y:{1:F2}">
                                        <Binding Path="LeftStickX" />
                                        <Binding Path="LeftStickY" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <!-- Triggers (center) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20"
                                    VerticalAlignment="Center" Margin="24,0">
                            <!-- LT -->
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="LT" Classes="label" HorizontalAlignment="Center" />
                                <Border Width="28" Height="88" CornerRadius="6"
                                        Background="#080B11" BorderBrush="#1F2533" BorderThickness="1">
                                    <Border VerticalAlignment="Bottom" CornerRadius="5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,100%" EndPoint="0%,0%">
                                                <GradientStop Color="#FFB547" Offset="0" />
                                                <GradientStop Color="#FFCF80" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Height>
                                            <Binding Path="LeftTrigger" Converter="{StaticResource TriggerHeight}" />
                                        </Border.Height>
                                    </Border>
                                </Border>
                                <TextBlock Text="{Binding LeftTrigger, StringFormat={}{0:P0}}"
                                           FontSize="10" Classes="mono" Foreground="#4A5066"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                            <!-- RT -->
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="RT" Classes="label" HorizontalAlignment="Center" />
                                <Border Width="28" Height="88" CornerRadius="6"
                                        Background="#080B11" BorderBrush="#1F2533" BorderThickness="1">
                                    <Border VerticalAlignment="Bottom" CornerRadius="5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,100%" EndPoint="0%,0%">
                                                <GradientStop Color="#FFB547" Offset="0" />
                                                <GradientStop Color="#FFCF80" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Height>
                                            <Binding Path="RightTrigger" Converter="{StaticResource TriggerHeight}" />
                                        </Border.Height>
                                    </Border>
                                </Border>
                                <TextBlock Text="{Binding RightTrigger, StringFormat={}{0:P0}}"
                                           FontSize="10" Classes="mono" Foreground="#4A5066"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Stick -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="Right Stick" Classes="label" HorizontalAlignment="Center" />
                            <Border Width="114" Height="114" CornerRadius="57"
                                    Background="#080B11"
                                    BorderBrush="#1F2533" BorderThickness="2"
                                    BoxShadow="inset 0 2 12 0 #40000000">
                                <Canvas Width="96" Height="96">
                                    <Line StartPoint="48,4" EndPoint="48,92" Stroke="#1F2533" StrokeThickness="1" />
                                    <Line StartPoint="4,48" EndPoint="92,48" Stroke="#1F2533" StrokeThickness="1" />
                                    <Ellipse Width="8" Height="8" Fill="Transparent"
                                             Stroke="#2A3345" StrokeThickness="1"
                                             Canvas.Left="44" Canvas.Top="44" />
                                    <!-- Cyan dot for right stick -->
                                    <Ellipse Width="14" Height="14"
                                             Fill="#00B7FF"
                                             Canvas.Left="{Binding RightStickX, Converter={StaticResource StickToCanvas}}"
                                             Canvas.Top="{Binding RightStickY, Converter={StaticResource StickToCanvas}, ConverterParameter=invert}" />
                                </Canvas>
                            </Border>
                            <TextBlock HorizontalAlignment="Center" FontSize="10"
                                       Classes="mono" Foreground="#4A5066">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="X:{0:F2}  Y:{1:F2}">
                                        <Binding Path="RightStickX" />
                                        <Binding Path="RightStickY" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="#1F2533" />

                    <!-- Button matrix: RAW | divider | OUTPUT -->
                    <Grid ColumnDefinitions="*,1,*">

                        <!-- RAW buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Spacing="16">
                            <!-- D-Pad RAW -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="D-PAD" Classes="eyebrow" HorizontalAlignment="Center" />
                                <Grid RowDefinitions="22,22,22" ColumnDefinitions="22,22,22">
                                    <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator"
                                             Fill="{Binding DpadUp, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator"
                                             Fill="{Binding DpadLeft, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator"
                                             Fill="{Binding DpadRight, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator"
                                             Fill="{Binding DpadDown, Converter={StaticResource StatusBrush}}" />
                                </Grid>
                            </StackPanel>

                            <!-- Face Buttons RAW -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="BUTTONS" Classes="eyebrow" HorizontalAlignment="Center" />
                                <Grid RowDefinitions="22,22,22" ColumnDefinitions="22,22,22">
                                    <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator"
                                             Fill="{Binding ButtonY, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator"
                                             Fill="{Binding ButtonX, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator"
                                             Fill="{Binding ButtonB, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator"
                                             Fill="{Binding ButtonA, Converter={StaticResource StatusBrush}}" />
                                </Grid>
                            </StackPanel>

                            <!-- Shoulders RAW -->
                            <StackPanel Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="SHOULDER" Classes="eyebrow" HorizontalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Padding="8,5" CornerRadius="6"
                                            Background="{Binding ButtonLB, Converter={StaticResource StatusBrush}}">
                                        <TextBlock Text="LB" FontSize="10" Foreground="#06070C" FontWeight="Bold" />
                                    </Border>
                                    <Border Padding="8,5" CornerRadius="6"
                                            Background="{Binding ButtonRB, Converter={StaticResource StatusBrush}}">
                                        <TextBlock Text="RB" FontSize="10" Foreground="#06070C" FontWeight="Bold" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Padding="6,4" CornerRadius="5"
                                            Background="{Binding ButtonBack, Converter={StaticResource StatusBrush}}">
                                        <TextBlock Text="Back" FontSize="9" Foreground="#06070C" />
                                    </Border>
                                    <Border Padding="6,4" CornerRadius="5"
                                            Background="{Binding ButtonStart, Converter={StaticResource StatusBrush}}">
                                        <TextBlock Text="Start" FontSize="9" Foreground="#06070C" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Divider -->
                        <Border Grid.Column="1" Width="1" Background="#1F2533" Margin="12,0" />

                        <!-- OUTPUT buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Spacing="16">

                            <!-- D-Pad OUT -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="D-PAD OUT" Classes="eyebrow" Foreground="#00FF95"
                                           HorizontalAlignment="Center" />
                                <Grid RowDefinitions="22,22,22" ColumnDefinitions="22,22,22">
                                    <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator"
                                             Fill="{Binding OutDpadUp, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator"
                                             Fill="{Binding OutDpadLeft, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator"
                                             Fill="{Binding OutDpadRight, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator"
                                             Fill="{Binding OutDpadDown, Converter={StaticResource GreenGrayBrush}}" />
                                </Grid>
                            </StackPanel>

                            <!-- Face Buttons OUT -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="BUTTONS OUT" Classes="eyebrow" Foreground="#00FF95"
                                           HorizontalAlignment="Center" />
                                <Grid RowDefinitions="22,22,22" ColumnDefinitions="22,22,22">
                                    <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator"
                                             Fill="{Binding OutButtonY, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator"
                                             Fill="{Binding OutButtonX, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator"
                                             Fill="{Binding OutButtonB, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator"
                                             Fill="{Binding OutButtonA, Converter={StaticResource GreenGrayBrush}}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
