<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:InputBusX.UI.ViewModels"
             xmlns:conv="using:InputBusX.UI.Converters"
             x:Class="InputBusX.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Resources>
        <conv:BoolToBrushConverter x:Key="StatusBrush"
                                   TrueBrush="#58D68D"
                                   FalseBrush="#354258" />
        <conv:BoolToBrushConverter x:Key="GreenGrayBrush"
                                   TrueBrush="#58D68D"
                                   FalseBrush="#354258" />
        <conv:StickToCanvasConverter x:Key="StickToCanvas" CanvasSize="96" />
        <conv:PercentageConverter x:Key="TriggerHeight" MaxHeight="88" />
        <conv:BoolToStringConverter x:Key="ConnectLabel" TrueValue="Stop" FalseValue="Start" />
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Spacing="16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="Home" Classes="eyebrow" />
                    <TextBlock Text="Dashboard" Classes="h1" />
                </StackPanel>

                <Border Grid.Column="1"
                        Classes="pill"
                        VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{Binding IsRunning, Converter={StaticResource GreenGrayBrush}}"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   FontSize="12"
                                   MaxWidth="240"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0"
                        Classes="stat-card"
                        Margin="0,0,8,0">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{Binding IsRunning, Converter={StaticResource GreenGrayBrush}}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="Connection" Classes="eyebrow" />
                        </StackPanel>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   Classes="muted"
                                   TextWrapping="Wrap" />
                        <Button Content="{Binding IsRunning, Converter={StaticResource ConnectLabel}}"
                                Command="{Binding ToggleConnectionCommand}"
                                IsEnabled="{Binding !IsConnecting}"
                                Classes="accent"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.Name="Toggle controller connection" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Classes="stat-card"
                        Margin="8,0">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#4DA3FF" VerticalAlignment="Center" />
                            <TextBlock Text="Active Profile" Classes="eyebrow" />
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveProfileName}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#7EE0AA"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Classes="stat-card"
                        Margin="8,0,0,0">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#E6B450" VerticalAlignment="Center" />
                            <TextBlock Text="Devices" Classes="eyebrow" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding ConnectedDevices}"
                                      AutomationProperties.Name="Connected devices list">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Classes="muted"
                                               Foreground="#F4F6FA"
                                               TextWrapping="Wrap"
                                               Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No devices connected"
                                   IsVisible="{Binding !ConnectedDevices.Count}"
                                   Classes="muted"
                                   FontStyle="Italic" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Classes="card">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#E6B450" VerticalAlignment="Center" />
                            <TextBlock Text="Real-time Input" Classes="section-header" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="#7C8798" VerticalAlignment="Center" />
                                <TextBlock Text="Raw input" Classes="muted" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="#58D68D" VerticalAlignment="Center" />
                                <TextBlock Text="Output" Classes="muted" Foreground="#7EE0AA" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto,*">
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="Left Stick" Classes="label" HorizontalAlignment="Center" />
                            <Border Width="120"
                                    Height="120"
                                    CornerRadius="60"
                                    Background="#0F1621"
                                    BorderBrush="#2B3749"
                                    BorderThickness="1"
                                    Padding="12">
                                <Canvas Width="96" Height="96">
                                    <Line StartPoint="48,4" EndPoint="48,92" Stroke="#2B3749" StrokeThickness="1" />
                                    <Line StartPoint="4,48" EndPoint="92,48" Stroke="#2B3749" StrokeThickness="1" />
                                    <Ellipse Width="8" Height="8" Fill="Transparent"
                                             Stroke="#3A465B" StrokeThickness="1"
                                             Canvas.Left="44" Canvas.Top="44" />
                                    <Ellipse Width="14" Height="14"
                                             Fill="#58D68D"
                                             Canvas.Left="{Binding LeftStickX, Converter={StaticResource StickToCanvas}}"
                                             Canvas.Top="{Binding LeftStickY, Converter={StaticResource StickToCanvas}, ConverterParameter=invert}" />
                                </Canvas>
                            </Border>
                            <TextBlock HorizontalAlignment="Center" Classes="mono" Foreground="#7C8798">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="X:{0:F2}  Y:{1:F2}">
                                        <Binding Path="LeftStickX" />
                                        <Binding Path="LeftStickY" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="24"
                                    VerticalAlignment="Center"
                                    Margin="32,0">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="LT" Classes="label" HorizontalAlignment="Center" />
                                <Border Width="32" Height="88" CornerRadius="6"
                                        Background="#0F1621" BorderBrush="#2B3749" BorderThickness="1">
                                    <Border VerticalAlignment="Bottom"
                                            CornerRadius="5"
                                            Background="#E6B450"
                                            Height="{Binding LeftTrigger, Converter={StaticResource TriggerHeight}}" />
                                </Border>
                                <TextBlock Text="{Binding LeftTrigger, StringFormat={}{0:P0}}"
                                           Classes="mono"
                                           Foreground="#7C8798"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="RT" Classes="label" HorizontalAlignment="Center" />
                                <Border Width="32" Height="88" CornerRadius="6"
                                        Background="#0F1621" BorderBrush="#2B3749" BorderThickness="1">
                                    <Border VerticalAlignment="Bottom"
                                            CornerRadius="5"
                                            Background="#E6B450"
                                            Height="{Binding RightTrigger, Converter={StaticResource TriggerHeight}}" />
                                </Border>
                                <TextBlock Text="{Binding RightTrigger, StringFormat={}{0:P0}}"
                                           Classes="mono"
                                           Foreground="#7C8798"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="Right Stick" Classes="label" HorizontalAlignment="Center" />
                            <Border Width="120"
                                    Height="120"
                                    CornerRadius="60"
                                    Background="#0F1621"
                                    BorderBrush="#2B3749"
                                    BorderThickness="1"
                                    Padding="12">
                                <Canvas Width="96" Height="96">
                                    <Line StartPoint="48,4" EndPoint="48,92" Stroke="#2B3749" StrokeThickness="1" />
                                    <Line StartPoint="4,48" EndPoint="92,48" Stroke="#2B3749" StrokeThickness="1" />
                                    <Ellipse Width="8" Height="8" Fill="Transparent"
                                             Stroke="#3A465B" StrokeThickness="1"
                                             Canvas.Left="44" Canvas.Top="44" />
                                    <Ellipse Width="14" Height="14"
                                             Fill="#4DA3FF"
                                             Canvas.Left="{Binding RightStickX, Converter={StaticResource StickToCanvas}}"
                                             Canvas.Top="{Binding RightStickY, Converter={StaticResource StickToCanvas}, ConverterParameter=invert}" />
                                </Canvas>
                            </Border>
                            <TextBlock HorizontalAlignment="Center" Classes="mono" Foreground="#7C8798">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="X:{0:F2}  Y:{1:F2}">
                                        <Binding Path="RightStickX" />
                                        <Binding Path="RightStickY" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <Separator />

                    <Grid ColumnDefinitions="*,1,*">
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="D-Pad" Classes="eyebrow" HorizontalAlignment="Center" />
                                <Grid RowDefinitions="24,24,24" ColumnDefinitions="24,24,24">
                                    <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator" Fill="{Binding DpadUp, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator" Fill="{Binding DpadLeft, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator" Fill="{Binding DpadRight, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator" Fill="{Binding DpadDown, Converter={StaticResource StatusBrush}}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Buttons" Classes="eyebrow" HorizontalAlignment="Center" />
                                <Grid RowDefinitions="24,24,24" ColumnDefinitions="24,24,24">
                                    <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator" Fill="{Binding ButtonY, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator" Fill="{Binding ButtonX, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator" Fill="{Binding ButtonB, Converter={StaticResource StatusBrush}}" />
                                    <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator" Fill="{Binding ButtonA, Converter={StaticResource StatusBrush}}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Shoulder" Classes="eyebrow" HorizontalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Classes="chip" Padding="8,5" Background="{Binding ButtonLB, Converter={StaticResource StatusBrush}}">
                                        <TextBlock Text="LB" FontSize="11" Foreground="#07130E" FontWeight="SemiBold" />
                                    </Border>
                                    <Border Classes="chip" Padding="8,5" Background="{Binding ButtonRB, Converter={StaticResource StatusBrush}}">
                                        <TextBlock Text="RB" FontSize="11" Foreground="#07130E" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" Width="1" Background="#283243" Margin="12,0" />

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="D-Pad Out" Classes="eyebrow" HorizontalAlignment="Center" Foreground="#7EE0AA" />
                                <Grid RowDefinitions="24,24,24" ColumnDefinitions="24,24,24">
                                    <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator" Fill="{Binding OutDpadUp, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator" Fill="{Binding OutDpadLeft, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator" Fill="{Binding OutDpadRight, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator" Fill="{Binding OutDpadDown, Converter={StaticResource GreenGrayBrush}}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Buttons Out" Classes="eyebrow" HorizontalAlignment="Center" Foreground="#7EE0AA" />
                                <Grid RowDefinitions="24,24,24" ColumnDefinitions="24,24,24">
                                    <Ellipse Grid.Row="0" Grid.Column="1" Classes="btn-indicator" Fill="{Binding OutButtonY, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="0" Classes="btn-indicator" Fill="{Binding OutButtonX, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="1" Grid.Column="2" Classes="btn-indicator" Fill="{Binding OutButtonB, Converter={StaticResource GreenGrayBrush}}" />
                                    <Ellipse Grid.Row="2" Grid.Column="1" Classes="btn-indicator" Fill="{Binding OutButtonA, Converter={StaticResource GreenGrayBrush}}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
