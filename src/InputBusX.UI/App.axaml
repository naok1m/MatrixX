<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:InputBusX.UI.Converters"
             x:Class="InputBusX.UI.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <conv:BoolToBrushConverter x:Key="BoolToConnFill"
                                   TrueBrush="#58D68D"
                                   FalseBrush="#3A465B" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://ReflexX/Styles/AppStyles.axaml" />
    </Application.Styles>
</Application>
