<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Clean desktop design system: neutral surfaces, restrained accent, 8px spacing rhythm. -->

    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Inter, Segoe UI, Arial" />
        <Setter Property="Foreground" Value="#F4F6FA" />
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#F4F6FA" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#F4F6FA" />
    </Style>

    <Style Selector="TextBlock.section-header">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#F4F6FA" />
    </Style>

    <Style Selector="TextBlock.label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#AAB2C0" />
    </Style>

    <Style Selector="TextBlock.eyebrow">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#7C8798" />
        <Setter Property="LetterSpacing" Value="1" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#7C8798" />
    </Style>

    <Style Selector="TextBlock.mono">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#D8DEE9" />
    </Style>

    <Style Selector="Border.topbar-shell">
        <Setter Property="Background" Value="#111722" />
        <Setter Property="BorderBrush" Value="#283243" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.card">
        <Setter Property="Background" Value="#131A25" />
        <Setter Property="BorderBrush" Value="#283243" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Border.card-interactive">
        <Setter Property="Background" Value="#131A25" />
        <Setter Property="BorderBrush" Value="#283243" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Border.card-interactive:pointerover">
        <Setter Property="BorderBrush" Value="#354258" />
    </Style>

    <Style Selector="Border.card-flush">
        <Setter Property="Background" Value="#131A25" />
        <Setter Property="BorderBrush" Value="#283243" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="Border.card-glow">
        <Setter Property="Background" Value="#13251F" />
        <Setter Property="BorderBrush" Value="#2C8C68" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Border.stat-card">
        <Setter Property="Background" Value="#131A25" />
        <Setter Property="BorderBrush" Value="#283243" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="MinHeight" Value="112" />
    </Style>

    <Style Selector="Border.section-panel">
        <Setter Property="Background" Value="#101722" />
        <Setter Property="BorderBrush" Value="#283243" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Border.item-card">
        <Setter Property="Background" Value="#182130" />
        <Setter Property="BorderBrush" Value="#283243" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="Border.item-card:pointerover">
        <Setter Property="Background" Value="#1C2637" />
        <Setter Property="BorderBrush" Value="#3A465B" />
    </Style>

    <Style Selector="Border.pill">
        <Setter Property="Background" Value="#182130" />
        <Setter Property="BorderBrush" Value="#2B3749" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="10,5" />
    </Style>

    <Style Selector="Border.pill-accent">
        <Setter Property="Background" Value="#0F2A22" />
        <Setter Property="BorderBrush" Value="#2C8C68" />
    </Style>

    <Style Selector="Border.pill-danger">
        <Setter Property="Background" Value="#351A22" />
        <Setter Property="BorderBrush" Value="#A94C61" />
    </Style>

    <Style Selector="Border.chip">
        <Setter Property="Background" Value="#182130" />
        <Setter Property="BorderBrush" Value="#2B3749" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="Button">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="#202B3B" />
        <Setter Property="Foreground" Value="#F4F6FA" />
        <Setter Property="BorderBrush" Value="#354258" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#263346" />
    </Style>

    <Style Selector="Button:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#1A2331" />
    </Style>

    <Style Selector="Button.accent">
        <Setter Property="Background" Value="#2FB477" />
        <Setter Property="Foreground" Value="#07130E" />
        <Setter Property="BorderBrush" Value="#45C98D" />
    </Style>

    <Style Selector="Button.accent /template/ ContentPresenter">
        <Setter Property="Background" Value="#2FB477" />
        <Setter Property="Foreground" Value="#07130E" />
        <Setter Property="BorderBrush" Value="#45C98D" />
    </Style>

    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#3CC283" />
    </Style>

    <Style Selector="Button.accent:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#249866" />
    </Style>

    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="#202B3B" />
        <Setter Property="Foreground" Value="#F4F6FA" />
        <Setter Property="BorderBrush" Value="#354258" />
    </Style>

    <Style Selector="Button.secondary /template/ ContentPresenter">
        <Setter Property="Background" Value="#202B3B" />
        <Setter Property="Foreground" Value="#F4F6FA" />
        <Setter Property="BorderBrush" Value="#354258" />
    </Style>

    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#AAB2C0" />
        <Setter Property="BorderBrush" Value="#354258" />
    </Style>

    <Style Selector="Button.ghost /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#AAB2C0" />
        <Setter Property="BorderBrush" Value="#354258" />
    </Style>

    <Style Selector="Button.ghost:pointerover">
        <Setter Property="Foreground" Value="#F4F6FA" />
    </Style>

    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#182130" />
    </Style>

    <Style Selector="Button.danger">
        <Setter Property="Background" Value="#A94C61" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#C25D73" />
    </Style>

    <Style Selector="Button.danger /template/ ContentPresenter">
        <Setter Property="Background" Value="#A94C61" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#C25D73" />
    </Style>

    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#B9576D" />
    </Style>

    <Style Selector="Button.icon">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#AAB2C0" />
    </Style>

    <Style Selector="ComboBox.topbar-chip">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="#0F1621" />
        <Setter Property="BorderBrush" Value="#2B3749" />
        <Setter Property="Foreground" Value="#F4F6FA" />
        <Setter Property="CaretBrush" Value="#58D68D" />
        <Setter Property="SelectionBrush" Value="#355B49" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style Selector="TextBox:pointerover /template/ Border">
        <Setter Property="BorderBrush" Value="#3A465B" />
    </Style>

    <Style Selector="TextBox:focus /template/ Border">
        <Setter Property="BorderBrush" Value="#58D68D" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="#0F1621" />
        <Setter Property="BorderBrush" Value="#2B3749" />
        <Setter Property="Foreground" Value="#F4F6FA" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="BorderBrush" Value="#3A465B" />
    </Style>

    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="#58D68D" />
    </Style>

    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#202B3B" />
    </Style>

    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#18382C" />
    </Style>

    <Style Selector="NumericUpDown">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Foreground" Value="#F4F6FA" />
    </Style>

    <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ Border">
        <Setter Property="Background" Value="#0F1621" />
        <Setter Property="BorderBrush" Value="#2B3749" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="#D8DEE9" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="CheckBox /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="#0F1621" />
        <Setter Property="BorderBrush" Value="#3A465B" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="#2FB477" />
        <Setter Property="BorderBrush" Value="#2FB477" />
    </Style>

    <Style Selector="ToggleSwitch">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Foreground" Value="#D8DEE9" />
    </Style>

    <Style Selector="Slider">
        <Setter Property="Foreground" Value="#2FB477" />
        <Setter Property="Background" Value="#2B3749" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="#D8DEE9" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1C2637" />
    </Style>

    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#18382C" />
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Foreground" Value="#7EE0AA" />
    </Style>

    <Style Selector="ListBoxItem.tab">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="#AAB2C0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBoxItem.tab:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1C2637" />
    </Style>

    <Style Selector="ListBoxItem.tab:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#203B31" />
    </Style>

    <Style Selector="ListBoxItem.tab:selected">
        <Setter Property="Foreground" Value="#7EE0AA" />
    </Style>

    <Style Selector="ListBoxItem.side">
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="#AAB2C0" />
    </Style>

    <Style Selector="Ellipse.status-dot">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
    </Style>

    <Style Selector="Ellipse.btn-indicator">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke" Value="#3A465B" />
    </Style>

    <Style Selector="Separator">
        <Setter Property="Margin" Value="0,8" />
        <Setter Property="Background" Value="#283243" />
        <Setter Property="Height" Value="1" />
    </Style>

    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>

    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="8" />
        <Setter Property="Margin" Value="4,0,0,0" />
    </Style>

    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="8" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#354258" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="#4A5870" />
    </Style>
</Styles>
