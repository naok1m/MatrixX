<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         MatrixX V2 — Premium gamer software design system
         ═══════════════════════════════════════════════════════════════════
         Surfaces (3 levels of depth):
           Void        : #06070C  (window background)
           Surface     : #0F1218  (cards, panels)
           Elevated    : #161A24  (hover, dropdown, popover)
         Borders:
           Soft        : #1F2533
           Hard        : #2A3345
         Accents:
           Primary     : #00FF95  (matrix green — brand)
           PrimaryDim  : #00B870  (pressed/active)
           PrimaryGlow : #4D00FF95
           Cyan        : #00B7FF  (data, secondary)
           Warn        : #FFB547
           Danger      : #FF3B5C
         Text:
           T1          : #F0F2F8  (primary)
           T2          : #8B92A8  (secondary)
           T3          : #4A5066  (tertiary / disabled)
        ═══════════════════════════════════════════════════════════════════ -->

    <!-- ═══ Global text ═══════════════════════════════════════════════════ -->
    <Style Selector="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#F0F2F8" />
    </Style>

    <!-- Section titles (page H1) -->
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#F0F2F8" />
    </Style>

    <!-- Card / sub-section title -->
    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#F0F2F8" />
    </Style>

    <!-- Panel section header (bold label above a list or group) -->
    <Style Selector="TextBlock.section-header">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#F0F2F8" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="LetterSpacing" Value="0.5" />
    </Style>

    <!-- Inline label above an input -->
    <Style Selector="TextBlock.label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#8B92A8" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!-- Tracking-spaced uppercase mini label -->
    <Style Selector="TextBlock.eyebrow">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#4A5066" />
        <Setter Property="LetterSpacing" Value="2" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#4A5066" />
    </Style>

    <!-- Numbers / stats — monospace for technical feel -->
    <Style Selector="TextBlock.mono">
        <Setter Property="FontFamily" Value="JetBrains Mono,Consolas,Courier New,monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#F0F2F8" />
    </Style>

    <!-- ═══ Cards ═══════════════════════════════════════════════════════════
         Three card variants: card (default), card-elevated (hover-lifted),
         card-flush (no padding for tables/lists).
        ════════════════════════════════════════════════════════════════════ -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="#0F1218" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderBrush" Value="#1F2533" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BoxShadow" Value="0 4 32 0 #60000000, 0 1 0 0 #0DFFFFFF" />
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" />
                </Transitions>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- card-interactive: adds hover lift + glow. Compose with .card -->
    <Style Selector="Border.card-interactive">
        <Setter Property="RenderTransform" Value="translateY(0px)" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut" />
                </Transitions>
            </Setter.Value>
        </Setter>
    </Style>
    <Style Selector="Border.card-interactive:pointerover">
        <Setter Property="BorderBrush" Value="#3A4A60" />
        <Setter Property="BoxShadow" Value="0 12 48 0 #90000000, 0 0 24 4 #4000FF95" />
        <Setter Property="RenderTransform" Value="translateY(-2px)" />
    </Style>

    <!-- Card with a permanent visible green glow (hero elements) -->
    <Style Selector="Border.card-glow">
        <Setter Property="Background" Value="#0A1A14" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderBrush" Value="#2000FF95" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BoxShadow" Value="0 0 32 8 #2A00FF95, 0 4 32 0 #60000000" />
    </Style>

    <Style Selector="Border.card-flush">
        <Setter Property="Background" Value="#0F1218" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="BorderBrush" Value="#1F2533" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ═══ Buttons ═══════════════════════════════════════════════════════
         Variants: accent (primary), secondary, ghost, danger, icon.
         All buttons get a press-scale microinteraction.
        ═══════════════════════════════════════════════════════════════════ -->

    <Style Selector="Button">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="RenderTransform" Value="scale(1)" />
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                </Transitions>
            </Setter.Value>
        </Setter>
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="RenderTransform" Value="scale(0.97)" />
    </Style>

    <!-- Primary / accent (matrix green) with glow via template border -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="#00FF95" />
        <Setter Property="Foreground" Value="#06070C" />
    </Style>
    <Style Selector="Button.accent /template/ Border#PART_ContentBorder">
        <Setter Property="BoxShadow" Value="0 0 0 0 transparent" />
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.18" />
                </Transitions>
            </Setter.Value>
        </Setter>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ Border#PART_ContentBorder">
        <Setter Property="BoxShadow" Value="0 0 20 4 #6000FF95, 0 4 8 0 #3000FF95" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#22FFAB" />
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#00B870" />
    </Style>
    <Style Selector="Button.accent:pressed /template/ Border#PART_ContentBorder">
        <Setter Property="BoxShadow" Value="0 0 8 2 #3000FF95" />
    </Style>

    <!-- Secondary (subtle filled) -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="#161A24" />
        <Setter Property="Foreground" Value="#F0F2F8" />
        <Setter Property="BorderBrush" Value="#2A3345" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1C2231" />
    </Style>

    <!-- Ghost (transparent + border) -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#8B92A8" />
        <Setter Property="BorderBrush" Value="#2A3345" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,7" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#0F1218" />
    </Style>
    <Style Selector="Button.ghost:pointerover">
        <Setter Property="Foreground" Value="#00FF95" />
        <Setter Property="BorderBrush" Value="#0000FF95" />
    </Style>

    <!-- Danger -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="#FF3B5C" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF5573" />
    </Style>

    <!-- Icon-only button (square, transparent) -->
    <Style Selector="Button.icon">
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#8B92A8" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#161A24" />
    </Style>
    <Style Selector="Button.icon:pointerover">
        <Setter Property="Foreground" Value="#F0F2F8" />
    </Style>

    <!-- ═══ Top Navigation tabs ═══════════════════════════════════════════
         Used in the main top bar: Home / Macros / Curve / Profiles / Config.
         Active tab gets a glowing underline.
        ═══════════════════════════════════════════════════════════════════ -->
    <Style Selector="ListBoxItem.tab">
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="MinHeight" Value="60" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#6F7689" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.18" Easing="CubicEaseOut" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.22" Easing="CubicEaseOut" />
                </Transitions>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- Hover: text brightens to white, no underline -->
    <Style Selector="ListBoxItem.tab:pointerover">
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="ListBoxItem.tab:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <!-- Selected: green text + subtle 2px green underline (no weight change) -->
    <Style Selector="ListBoxItem.tab:selected">
        <Setter Property="Foreground" Value="#00FF95" />
        <Setter Property="BorderBrush" Value="#00FF95" />
    </Style>
    <Style Selector="ListBoxItem.tab:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <!-- Selected + hover: keep green, slight brightness boost -->
    <Style Selector="ListBoxItem.tab:selected:pointerover">
        <Setter Property="Foreground" Value="#22FFAB" />
    </Style>

    <!-- ═══ Sidebar nav (vertical) — used inside views (e.g. Macros categories) ═ -->
    <Style Selector="ListBoxItem.side">
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#8B92A8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="ListBoxItem.side:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#161A24" />
    </Style>
    <Style Selector="ListBoxItem.side:pointerover">
        <Setter Property="Foreground" Value="#F0F2F8" />
    </Style>
    <Style Selector="ListBoxItem.side:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#0A2218" />
    </Style>
    <Style Selector="ListBoxItem.side:selected">
        <Setter Property="Foreground" Value="#00FF95" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ═══ Pills / Chips / Badges ═══════════════════════════════════════ -->

    <!-- Status pill (used in StatusBar, e.g. "Connected") -->
    <Style Selector="Border.pill">
        <Setter Property="Background" Value="#161A24" />
        <Setter Property="CornerRadius" Value="100" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="BorderBrush" Value="#1F2533" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.pill-accent">
        <Setter Property="Background" Value="#0A2218" />
        <Setter Property="BorderBrush" Value="#0000FF95" />
    </Style>

    <Style Selector="Border.pill-danger">
        <Setter Property="Background" Value="#1F0A12" />
        <Setter Property="BorderBrush" Value="#80FF3B5C" />
    </Style>

    <!-- Chip (for game selector, tags) -->
    <Style Selector="Border.chip">
        <Setter Property="Background" Value="#161A24" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="BorderBrush" Value="#2A3345" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ═══ Sliders ═══════════════════════════════════════════════════════
         Track 4px with green→cyan gradient fill.
         Thumb 16px green with glow ring; grows to 20px on drag.
        ═══════════════════════════════════════════════════════════════════ -->
    <Style Selector="Slider">
        <Setter Property="Background" Value="#1F2533" />
        <Setter Property="Foreground" Value="#00FF95" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <!-- Filled (decrease) track — solid green with strong glow halo -->
    <Style Selector="Slider /template/ Track > Border">
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="#00FF95" />
        <Setter Property="BoxShadow" Value="0 0 8 0 #6000FF95, 0 0 16 0 #3000FF95" />
    </Style>

    <!-- Unfilled (increase) track — dark base -->
    <Style Selector="Slider /template/ Track > RepeatButton:last-child /template/ Border">
        <Setter Property="Background" Value="#1F2533" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <!-- Thumb — bright green dot with strong glow halo -->
    <Style Selector="Slider /template/ Thumb /template/ Border">
        <Setter Property="Background" Value="#00FF95" />
        <Setter Property="CornerRadius" Value="100" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="BoxShadow" Value="0 0 0 4 #5000FF95, 0 0 14 2 #6000FF95, 0 0 28 6 #3000FF95" />
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.15" Easing="CubicEaseOut" />
                    <DoubleTransition Property="Height" Duration="0:0:0.15" Easing="CubicEaseOut" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.15" />
                </Transitions>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Thumb hover — larger + brighter glow -->
    <Style Selector="Slider /template/ Thumb:pointerover /template/ Border">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="BoxShadow" Value="0 0 0 6 #6000FF95, 0 0 20 4 #8000FF95, 0 0 36 8 #4000FF95" />
    </Style>

    <!-- Thumb press — max size + brightest glow -->
    <Style Selector="Slider /template/ Thumb:pressed /template/ Border">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Background" Value="#22FFAB" />
        <Setter Property="BoxShadow" Value="0 0 0 8 #8000FF95, 0 0 28 6 #A000FF95, 0 0 48 10 #5000FF95" />
    </Style>

    <!-- ═══ Toggle (CheckBox styled as iOS-pill) ═══════════════════════════ -->
    <!-- Avalonia's default ToggleSwitch already looks pill-ish; we re-skin
         CheckBox to render compactly with our palette. ToggleSwitch is the
         primary toggle component. -->
    <Style Selector="ToggleSwitch">
        <Setter Property="MinWidth" Value="48" />
        <Setter Property="MinHeight" Value="24" />
    </Style>
    <Style Selector="ToggleSwitch /template/ Border#OuterBorder">
        <Setter Property="Background" Value="#161A24" />
        <Setter Property="BorderBrush" Value="#2A3345" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="100" />
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="24" />
    </Style>
    <Style Selector="ToggleSwitch:checked /template/ Border#OuterBorder">
        <Setter Property="Background" Value="#0A2218" />
        <Setter Property="BorderBrush" Value="#00FF95" />
    </Style>
    <Style Selector="ToggleSwitch /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="44" />
    </Style>
    <Style Selector="ToggleSwitch /template/ Grid#SwitchKnob">
        <Setter Property="Background" Value="#8B92A8" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>
    <Style Selector="ToggleSwitch:checked /template/ Grid#SwitchKnob">
        <Setter Property="Background" Value="#00FF95" />
    </Style>

    <!-- Default CheckBox (kept for places that need it) -->
    <Style Selector="CheckBox /template/ Border#NormalRectangle">
        <Setter Property="BorderBrush" Value="#2A3345" />
        <Setter Property="Background" Value="#0F1218" />
        <Setter Property="CornerRadius" Value="5" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="#00FF95" />
        <Setter Property="BorderBrush" Value="#00FF95" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Path">
        <Setter Property="Stroke" Value="#06070C" />
    </Style>

    <!-- ═══ Inputs (TextBox, ComboBox, NumericUpDown) ══════════════════════ -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#0F1218" />
        <Setter Property="BorderBrush" Value="#1F2533" />
        <Setter Property="Foreground" Value="#F0F2F8" />
        <Setter Property="CaretBrush" Value="#00FF95" />
        <Setter Property="SelectionBrush" Value="#0A2218" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="36" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border">
        <Setter Property="BorderBrush" Value="#00FF95" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border">
        <Setter Property="BorderBrush" Value="#2A3345" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="#0F1218" />
        <Setter Property="BorderBrush" Value="#1F2533" />
        <Setter Property="Foreground" Value="#F0F2F8" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,4" />
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="Background" Value="#0F1218" />
        <Setter Property="BorderBrush" Value="#2A3345" />
    </Style>
    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="#00FF95" />
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#0A2218" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#161A24" />
    </Style>

    <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ Border">
        <Setter Property="Background" Value="#0F1218" />
        <Setter Property="BorderBrush" Value="#1F2533" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <!-- ═══ ListBox base ══════════════════════════════════════════════════ -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <!-- Default ListBoxItem (rare — most lists use .side or .tab classes) -->
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Foreground" Value="#F0F2F8" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#161A24" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#0A2218" />
    </Style>
    <Style Selector="ListBoxItem:selected">
        <Setter Property="Foreground" Value="#00FF95" />
    </Style>

    <!-- ═══ Indicators ════════════════════════════════════════════════════ -->
    <Style Selector="Ellipse.status-dot">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style Selector="Ellipse.btn-indicator">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="Stroke" Value="#2A3345" />
    </Style>

    <!-- ═══ Separators ═══════════════════════════════════════════════════ -->
    <Style Selector="Separator">
        <Setter Property="Margin" Value="0,8" />
        <Setter Property="Background" Value="#1F2533" />
        <Setter Property="Height" Value="1" />
    </Style>

    <!-- ═══ ScrollBars (slim 6px, accent on hover) ════════════════════════ -->
    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="6" />
        <Setter Property="Margin" Value="2,0,0,0" />
    </Style>
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="6" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>
    <Style Selector="ScrollBar /template/ Border#VerticalRoot">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#1F2533" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="#5000FF95" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pressed">
        <Setter Property="Background" Value="#00FF95" />
    </Style>

</Styles>
