<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ─── Design tokens (dark navy-black theme) ───────────────────────────
         BG        : #0B0D12
         Surface1  : #0D0F16  (sidebar)
         Surface2  : #131820  (cards)
         Surface3  : #0E1118  (inputs / inner panels)
         Border1   : #1D2235  (card / control borders)
         Border2   : #252B3F  (input focus ring hints)
         Accent    : #00FF9C  (primary neon green)
         AccentGlow: #33FFB3  (hover / glow)
         AccentDim : #00C97A  (pressed)
         Cyan      : #00CFFF  (secondary accent)
         Text      : #E2E4EE
         TextMuted : #6A7090
         TextDim   : #2D3450
         Danger    : #FF4D6A
    ─────────────────────────────────────────────────────────────────────── -->

    <!-- ─── Global text ─────────────────────────────────────────────────── -->
    <Style Selector="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#E2E4EE" />
    </Style>

    <!-- ═══ Cards ═══════════════════════════════════════════════════════════ -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="#131820" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="BorderBrush" Value="#1D2235" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BoxShadow" Value="0 2 20 0 #28000000" />
    </Style>

    <!-- Inner section panels -->
    <Style Selector="Border.section-panel">
        <Setter Property="Background" Value="#0E1118" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="BorderBrush" Value="#1D2235" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Highlight panel (accent left border, used in macro sections) -->
    <Style Selector="Border.highlight-panel">
        <Setter Property="Background" Value="#0A1018" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="BorderBrush" Value="#1D2235" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ═══ Typography ═══════════════════════════════════════════════════════ -->
    <Style Selector="TextBlock.section-header">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Foreground" Value="#E2E4EE" />
    </Style>

    <Style Selector="TextBlock.label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#6A7090" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#3D4560" />
    </Style>

    <!-- Sidebar section category label -->
    <Style Selector="TextBlock.nav-section">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#2D3450" />
        <Setter Property="Margin" Value="16,10,0,2" />
    </Style>

    <!-- ═══ Buttons ═══════════════════════════════════════════════════════════ -->

    <!-- Base button — press opacity feedback on all buttons -->
    <Style Selector="Button">
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.08" />
                </Transitions>
            </Setter.Value>
        </Setter>
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="Opacity" Value="0.82" />
    </Style>

    <!-- Primary / accent (neon green) -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="#00FF9C" />
        <Setter Property="Foreground" Value="#0B0D12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#33FFB3" />
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#00C97A" />
    </Style>

    <!-- Danger (red) -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="#FF4D6A" />
        <Setter Property="Foreground" Value="#0B0D12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#FF7087" />
    </Style>
    <Style Selector="Button.danger:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#E0304A" />
    </Style>

    <!-- Secondary (subtle dark bg) -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="#1A1E2E" />
        <Setter Property="Foreground" Value="#C0C4DC" />
        <Setter Property="BorderBrush" Value="#252B3F" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1E2438" />
    </Style>

    <!-- Ghost (transparent with border) -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#6A7090" />
        <Setter Property="BorderBrush" Value="#1D2235" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#0E1520" />
    </Style>
    <Style Selector="Button.ghost:pointerover">
        <Setter Property="Foreground" Value="#00FF9C" />
        <Setter Property="BorderBrush" Value="#00FF9C30" />
    </Style>

    <!-- ═══ Navigation items ═══════════════════════════════════════════════ -->
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="Margin" Value="2,1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#6A7090" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#141826" />
    </Style>
    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Foreground" Value="#A0AACE" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#0B1F18" />
    </Style>
    <Style Selector="ListBoxItem:selected">
        <Setter Property="Foreground" Value="#00FF9C" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ═══ Indicators / Ellipses ════════════════════════════════════════ -->
    <Style Selector="Ellipse.status-dot">
        <Setter Property="Width" Value="9" />
        <Setter Property="Height" Value="9" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style Selector="Ellipse.btn-indicator">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="Stroke" Value="#252B3F" />
    </Style>

    <!-- ═══ Tags / Chips ══════════════════════════════════════════════════ -->
    <Style Selector="Border.tag">
        <Setter Property="Background" Value="#141826" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="BorderBrush" Value="#1D2235" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.badge">
        <Setter Property="Background" Value="#0A1F18" />
        <Setter Property="CornerRadius" Value="100" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <!-- ═══ Separators ══════════════════════════════════════════════════ -->
    <Style Selector="Separator">
        <Setter Property="Margin" Value="0,8" />
        <Setter Property="Background" Value="#1D2235" />
        <Setter Property="Height" Value="1" />
    </Style>

    <!-- ═══ ListBox — transparent bg, no border ════════════════════════ -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <!-- ═══ Sliders — refined track + thumb ═══════════════════════════ -->
    <Style Selector="Slider /template/ Thumb">
        <Setter Property="Background" Value="#00FF9C" />
        <Setter Property="Foreground" Value="#00FF9C" />
    </Style>
    <Style Selector="Slider /template/ Thumb /template/ Border">
        <Setter Property="Background" Value="#00FF9C" />
        <Setter Property="CornerRadius" Value="100" />
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
    </Style>
    <Style Selector="Slider /template/ Thumb:pointerover /template/ Border">
        <Setter Property="Background" Value="#33FFB3" />
        <Setter Property="BoxShadow" Value="0 0 8 2 #4000FF9C" />
    </Style>
    <Style Selector="Slider /template/ Thumb:pressed /template/ Border">
        <Setter Property="Background" Value="#00C97A" />
    </Style>
    <!-- Filled track portion -->
    <Style Selector="Slider /template/ Track > Border">
        <Setter Property="Background" Value="#00FF9C" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>
    <!-- Overall slider (background = unfilled track) -->
    <Style Selector="Slider">
        <Setter Property="Background" Value="#1D2235" />
        <Setter Property="Foreground" Value="#00FF9C" />
    </Style>

    <!-- ═══ NumericUpDown ════════════════════════════════════════════ -->
    <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ Border">
        <Setter Property="Background" Value="#0E1118" />
        <Setter Property="BorderBrush" Value="#1D2235" />
    </Style>

    <!-- ═══ ComboBox ════════════════════════════════════════════════ -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="#0E1118" />
        <Setter Property="BorderBrush" Value="#1D2235" />
        <Setter Property="Foreground" Value="#E2E4EE" />
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="Background" Value="#131820" />
        <Setter Property="BorderBrush" Value="#00FF9C60" />
    </Style>
    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="#00FF9C" />
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#0A1F18" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#141826" />
    </Style>

    <!-- ═══ TextBox ══════════════════════════════════════════════════ -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#0E1118" />
        <Setter Property="BorderBrush" Value="#1D2235" />
        <Setter Property="Foreground" Value="#E2E4EE" />
        <Setter Property="CaretBrush" Value="#00FF9C" />
        <Setter Property="SelectionBrush" Value="#0A2A1E" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border">
        <Setter Property="BorderBrush" Value="#00FF9C" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border">
        <Setter Property="BorderBrush" Value="#252B3F" />
    </Style>

    <!-- ═══ CheckBox ═════════════════════════════════════════════════ -->
    <Style Selector="CheckBox /template/ Border#NormalRectangle">
        <Setter Property="BorderBrush" Value="#252B3F" />
        <Setter Property="Background" Value="#0E1118" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="#00FF9C" />
        <Setter Property="BorderBrush" Value="#00FF9C" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Path">
        <Setter Property="Stroke" Value="#0B0D12" />
    </Style>

    <!-- ═══ ScrollViewer ═════════════════════════════════════════════ -->
    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>

    <!-- ═══ ScrollBar — slim 6px style ══════════════════════════════ -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="6" />
        <Setter Property="Margin" Value="2,0,0,0" />
    </Style>
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="6" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>
    <Style Selector="ScrollBar /template/ Border#VerticalRoot">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#1D2235" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="#00FF9C50" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pressed">
        <Setter Property="Background" Value="#00FF9C" />
    </Style>

</Styles>
